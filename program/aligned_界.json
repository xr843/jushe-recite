[
 {
  "id": "序-1",
  "pin": "序分",
  "localNo": "序",
  "globalNo": 1,
  "start": 0.5,
  "end": 8.46,
  "dur": 7.96,
  "nchars": 28,
  "text": "诸一切种诸冥灭拔众生出生死泥敬礼如是如理师对法藏论我当说",
  "flag": ""
 },
 {
  "id": "序-2",
  "pin": "序分",
  "localNo": "序",
  "globalNo": 2,
  "start": 8.46,
  "end": 16.38,
  "dur": 7.92,
  "nchars": 28,
  "text": "净慧随行名对法及能得此诸慧论摄彼胜义依彼故此立对法俱舍名",
  "flag": ""
 },
 {
  "id": "序-3",
  "pin": "序分",
  "localNo": "序",
  "globalNo": 3,
  "start": 16.38,
  "end": 24.28,
  "dur": 7.9,
  "nchars": 28,
  "text": "若离择法定无余能灭诸惑胜方便由惑世间漂有海因此传佛说对法",
  "flag": ""
 },
 {
  "id": "界-1",
  "pin": "界品",
  "localNo": 1,
  "globalNo": 4,
  "start": 24.28,
  "end": 30.14,
  "dur": 5.86,
  "nchars": 20,
  "text": "有漏无漏法除道余有为于彼漏随增故说名有漏",
  "flag": ""
 },
 {
  "id": "界-2",
  "pin": "界品",
  "localNo": 2,
  "globalNo": 5,
  "start": 30.14,
  "end": 35.92,
  "dur": 5.78,
  "nchars": 20,
  "text": "无漏谓道谛及三种无为谓虚空二灭此中空无碍",
  "flag": ""
 },
 {
  "id": "界-3",
  "pin": "界品",
  "localNo": 3,
  "globalNo": 6,
  "start": 35.92,
  "end": 41.74,
  "dur": 5.82,
  "nchars": 20,
  "text": "择灭谓离系随系事各别毕竟碍当生别得非择灭",
  "flag": ""
 },
 {
  "id": "界-4",
  "pin": "界品",
  "localNo": 4,
  "globalNo": 7,
  "start": 41.74,
  "end": 47.54,
  "dur": 5.8,
  "nchars": 20,
  "text": "又诸有为法谓色等五蕴亦世路言依有离有事等",
  "flag": ""
 },
 {
  "id": "界-5",
  "pin": "界品",
  "localNo": 5,
  "globalNo": 8,
  "start": 47.54,
  "end": 53.32,
  "dur": 5.78,
  "nchars": 20,
  "text": "有漏名取蕴亦说为有诤及苦集世间见处三有等",
  "flag": ""
 },
 {
  "id": "界-6",
  "pin": "界品",
  "localNo": 6,
  "globalNo": 9,
  "start": 53.32,
  "end": 59.12,
  "dur": 5.8,
  "nchars": 20,
  "text": "色者唯五根五境及无表彼识依净色名眼等五根",
  "flag": ""
 },
 {
  "id": "界-7",
  "pin": "界品",
  "localNo": 7,
  "globalNo": 10,
  "start": 59.12,
  "end": 64.84,
  "dur": 5.72,
  "nchars": 20,
  "text": "色二或二十声唯有八种味六香四种触十一为性",
  "flag": ""
 },
 {
  "id": "界-8",
  "pin": "界品",
  "localNo": 8,
  "globalNo": 11,
  "start": 64.84,
  "end": 70.64,
  "dur": 5.8,
  "nchars": 20,
  "text": "乱心无心等随流净不净大种所造性由此说无表",
  "flag": ""
 },
 {
  "id": "界-9",
  "pin": "界品",
  "localNo": 9,
  "globalNo": 12,
  "start": 70.64,
  "end": 76.36,
  "dur": 5.72,
  "nchars": 20,
  "text": "大种谓四界即地水火风能成持等业坚湿暖动性",
  "flag": ""
 },
 {
  "id": "界-10",
  "pin": "界品",
  "localNo": 10,
  "globalNo": 13,
  "start": 76.36,
  "end": 82.02,
  "dur": 5.66,
  "nchars": 20,
  "text": "地谓显形色随世想立名水火亦复然风即界亦尔",
  "flag": ""
 },
 {
  "id": "界-11",
  "pin": "界品",
  "localNo": 11,
  "globalNo": 14,
  "start": 82.02,
  "end": 87.7,
  "dur": 5.68,
  "nchars": 20,
  "text": "此中根与境许即十处界受领纳随触想取像为体",
  "flag": ""
 },
 {
  "id": "界-12",
  "pin": "界品",
  "localNo": 12,
  "globalNo": 15,
  "start": 87.7,
  "end": 91.98,
  "dur": 4.28,
  "nchars": 20,
  "text": "四余名行蕴如是受等三及无表无为名法处法界",
  "flag": ""
 },
 {
  "id": "界-13",
  "pin": "界品",
  "localNo": 13,
  "globalNo": 16,
  "start": 91.98,
  "end": 99.1,
  "dur": 7.12,
  "nchars": 20,
  "text": "识谓各了别此即名意处及七界应知六识转为意",
  "flag": ""
 },
 {
  "id": "界-14",
  "pin": "界品",
  "localNo": 14,
  "globalNo": 17,
  "start": 99.1,
  "end": 104.8,
  "dur": 5.7,
  "nchars": 20,
  "text": "由即六识身无间灭为意成第六依故十八界应知",
  "flag": ""
 },
 {
  "id": "界-15",
  "pin": "界品",
  "localNo": 15,
  "globalNo": 18,
  "start": 104.8,
  "end": 110.46,
  "dur": 5.66,
  "nchars": 20,
  "text": "总摄一切法由一蕴处界摄自性非余以离他性故",
  "flag": ""
 },
 {
  "id": "界-16",
  "pin": "界品",
  "localNo": 16,
  "globalNo": 19,
  "start": 110.46,
  "end": 116.16,
  "dur": 5.7,
  "nchars": 20,
  "text": "类境识同故虽二界体一然为令端严眼等各生二",
  "flag": ""
 },
 {
  "id": "界-17",
  "pin": "界品",
  "localNo": 17,
  "globalNo": 20,
  "start": 116.16,
  "end": 121.9,
  "dur": 5.74,
  "nchars": 20,
  "text": "聚生门种族是蕴处界义愚根乐三故说蕴处界三",
  "flag": ""
 },
 {
  "id": "界-18",
  "pin": "界品",
  "localNo": 18,
  "globalNo": 21,
  "start": 122.13,
  "end": 127.64,
  "dur": 5.51,
  "nchars": 20,
  "text": "诤根生死因及次第因故于诸心所法受想别为蕴",
  "flag": ""
 },
 {
  "id": "界-19",
  "pin": "界品",
  "localNo": 19,
  "globalNo": 22,
  "start": 127.64,
  "end": 133.24,
  "dur": 5.6,
  "nchars": 20,
  "text": "蕴不摄无为义不相应故随粗染器等界别次第立",
  "flag": ""
 },
 {
  "id": "界-20",
  "pin": "界品",
  "localNo": 20,
  "globalNo": 23,
  "start": 133.24,
  "end": 138.92,
  "dur": 5.68,
  "nchars": 20,
  "text": "前五境唯现四境唯所造余用远速明或随处次第",
  "flag": ""
 },
 {
  "id": "界-21",
  "pin": "界品",
  "localNo": 21,
  "globalNo": 24,
  "start": 138.92,
  "end": 144.44,
  "dur": 5.52,
  "nchars": 20,
  "text": "为差别最胜摄多增上法故一处名色一名为法处",
  "flag": ""
 },
 {
  "id": "界-22",
  "pin": "界品",
  "localNo": 22,
  "globalNo": 25,
  "start": 144.44,
  "end": 150.22,
  "dur": 5.78,
  "nchars": 20,
  "text": "牟尼说法蕴数有八十千彼体语或名此色行蕴摄",
  "flag": ""
 },
 {
  "id": "界-23",
  "pin": "界品",
  "localNo": 23,
  "globalNo": 26,
  "start": 150.22,
  "end": 155.94,
  "dur": 5.72,
  "nchars": 20,
  "text": "有言诸法蕴量如彼论说或随蕴等言如实行对治",
  "flag": ""
 },
 {
  "id": "界-24",
  "pin": "界品",
  "localNo": 24,
  "globalNo": 27,
  "start": 155.94,
  "end": 161.5,
  "dur": 5.56,
  "nchars": 20,
  "text": "如是余蕴等各随其所应摄在前说中应审观自相",
  "flag": ""
 },
 {
  "id": "界-25",
  "pin": "界品",
  "localNo": 25,
  "globalNo": 28,
  "start": 161.5,
  "end": 167.3,
  "dur": 5.8,
  "nchars": 20,
  "text": "空界谓窍隙传说是明暗识界有漏识有情生所依",
  "flag": ""
 },
 {
  "id": "界-26",
  "pin": "界品",
  "localNo": 26,
  "globalNo": 29,
  "start": 167.3,
  "end": 172.96,
  "dur": 5.66,
  "nchars": 20,
  "text": "一有见谓色十有色有对此除色声八无记余三种",
  "flag": ""
 },
 {
  "id": "界-27",
  "pin": "界品",
  "localNo": 27,
  "globalNo": 30,
  "start": 172.96,
  "end": 178.64,
  "dur": 5.68,
  "nchars": 20,
  "text": "欲界系十八色界系十四除香味二识无色系后三",
  "flag": ""
 },
 {
  "id": "界-28",
  "pin": "界品",
  "localNo": 28,
  "globalNo": 31,
  "start": 178.64,
  "end": 184.36,
  "dur": 5.72,
  "nchars": 20,
  "text": "意法意识通所余唯有漏五识唯寻伺后三三余无",
  "flag": ""
 },
 {
  "id": "界-29",
  "pin": "界品",
  "localNo": 29,
  "globalNo": 32,
  "start": 184.36,
  "end": 190.04,
  "dur": 5.68,
  "nchars": 20,
  "text": "说五无分别由计度随念以意地散慧意诸念为体",
  "flag": ""
 },
 {
  "id": "界-30",
  "pin": "界品",
  "localNo": 30,
  "globalNo": 33,
  "start": 190.04,
  "end": 195.58,
  "dur": 5.54,
  "nchars": 20,
  "text": "七心法界半有所缘余无前八界及声无执受余二",
  "flag": ""
 },
 {
  "id": "界-31",
  "pin": "界品",
  "localNo": 31,
  "globalNo": 34,
  "start": 195.58,
  "end": 201.16,
  "dur": 5.58,
  "nchars": 20,
  "text": "触界中有二余九色所造法一分亦然十色可积集",
  "flag": ""
 },
 {
  "id": "界-32",
  "pin": "界品",
  "localNo": 32,
  "globalNo": 35,
  "start": 201.16,
  "end": 206.64,
  "dur": 5.48,
  "nchars": 20,
  "text": "谓唯外四界能斫及所斫亦所烧能称能烧所称诤",
  "flag": ""
 },
 {
  "id": "界-33",
  "pin": "界品",
  "localNo": 33,
  "globalNo": 36,
  "start": 206.72,
  "end": 212.46,
  "dur": 5.74,
  "nchars": 20,
  "text": "内五有熟养声无异熟生八无碍等流亦异熟生性",
  "flag": ""
 },
 {
  "id": "界-34",
  "pin": "界品",
  "localNo": 34,
  "globalNo": 37,
  "start": 212.46,
  "end": 218.18,
  "dur": 5.72,
  "nchars": 20,
  "text": "余三实唯法剎那唯后三眼与眼识界独俱得非等",
  "flag": ""
 },
 {
  "id": "界-35",
  "pin": "界品",
  "localNo": 35,
  "globalNo": 38,
  "start": 218.18,
  "end": 223.9,
  "dur": 5.72,
  "nchars": 20,
  "text": "内十二眼等色等六为外法同分余二作不作自业",
  "flag": ""
 },
 {
  "id": "界-36",
  "pin": "界品",
  "localNo": 36,
  "globalNo": 39,
  "start": 223.9,
  "end": 229.64,
  "dur": 5.74,
  "nchars": 20,
  "text": "十五唯修断后三界通三不染非六生色定非见断",
  "flag": ""
 },
 {
  "id": "界-37",
  "pin": "界品",
  "localNo": 37,
  "globalNo": 40,
  "start": 229.64,
  "end": 235.26,
  "dur": 5.62,
  "nchars": 20,
  "text": "眼法界一分八种说名见五识俱生慧非见不度故",
  "flag": ""
 },
 {
  "id": "界-38",
  "pin": "界品",
  "localNo": 38,
  "globalNo": 41,
  "start": 235.26,
  "end": 240.9,
  "dur": 5.64,
  "nchars": 20,
  "text": "眼见色同分非彼能依识传说不能观被障诸色故",
  "flag": ""
 },
 {
  "id": "界-39",
  "pin": "界品",
  "localNo": 39,
  "globalNo": 42,
  "start": 240.9,
  "end": 246.58,
  "dur": 5.68,
  "nchars": 20,
  "text": "或二眼俱时见色分明故眼耳意根境不至三相违",
  "flag": ""
 },
 {
  "id": "界-40",
  "pin": "界品",
  "localNo": 40,
  "globalNo": 43,
  "start": 246.58,
  "end": 252.3,
  "dur": 5.72,
  "nchars": 20,
  "text": "应知鼻等三唯取等量境后依唯过去五识依或俱",
  "flag": ""
 },
 {
  "id": "界-41",
  "pin": "界品",
  "localNo": 41,
  "globalNo": 44,
  "start": 252.3,
  "end": 257.82,
  "dur": 5.52,
  "nchars": 20,
  "text": "随根变识异故眼等名依彼及不共因故随根说识",
  "flag": ""
 },
 {
  "id": "界-42",
  "pin": "界品",
  "localNo": 42,
  "globalNo": 45,
  "start": 257.82,
  "end": 263.52,
  "dur": 5.7,
  "nchars": 20,
  "text": "眼不下于身色识非上眼色于识一切二于身亦然",
  "flag": ""
 },
 {
  "id": "界-43",
  "pin": "界品",
  "localNo": 43,
  "globalNo": 46,
  "start": 263.52,
  "end": 269.12,
  "dur": 5.6,
  "nchars": 20,
  "text": "如眼耳亦然次三皆自地身识自下地意不定应知",
  "flag": ""
 },
 {
  "id": "界-44",
  "pin": "界品",
  "localNo": 44,
  "globalNo": 47,
  "start": 269.12,
  "end": 274.8,
  "dur": 5.68,
  "nchars": 20,
  "text": "五外二所识常法界无为法一分是根并内界十二",
  "flag": ""
 }
]