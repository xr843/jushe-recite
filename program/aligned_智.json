[
 {
  "id": "智-1",
  "pin": "智品",
  "localNo": 1,
  "globalNo": 504,
  "start": 0.0,
  "end": 5.44,
  "dur": 5.44,
  "nchars": 20,
  "text": "圣慧忍非智尽无生非见余二有漏慧皆智六见性",
  "flag": ""
 },
 {
  "id": "智-2",
  "pin": "智品",
  "localNo": 2,
  "globalNo": 505,
  "start": 5.44,
  "end": 10.96,
  "dur": 5.52,
  "nchars": 20,
  "text": "智十总有二有漏无漏别有漏称世俗无漏名法类",
  "flag": ""
 },
 {
  "id": "智-3",
  "pin": "智品",
  "localNo": 3,
  "globalNo": 506,
  "start": 10.96,
  "end": 16.34,
  "dur": 5.38,
  "nchars": 20,
  "text": "世俗遍为境法智及类智如次欲上界苦等谛为境",
  "flag": ""
 },
 {
  "id": "智-4",
  "pin": "智品",
  "localNo": 4,
  "globalNo": 507,
  "start": 16.34,
  "end": 21.76,
  "dur": 5.42,
  "nchars": 20,
  "text": "法类由境别立苦等四名皆通尽无生初唯苦集类",
  "flag": ""
 },
 {
  "id": "智-5",
  "pin": "智品",
  "localNo": 5,
  "globalNo": 508,
  "start": 21.76,
  "end": 27.1,
  "dur": 5.34,
  "nchars": 20,
  "text": "法类道世俗有成他心智于胜地根位去来世不知",
  "flag": ""
 },
 {
  "id": "智-6",
  "pin": "智品",
  "localNo": 6,
  "globalNo": 509,
  "start": 27.1,
  "end": 32.48,
  "dur": 5.38,
  "nchars": 20,
  "text": "法类不相知声闻麟喻佛如次知见道二三念一切",
  "flag": ""
 },
 {
  "id": "智-7",
  "pin": "智品",
  "localNo": 7,
  "globalNo": 510,
  "start": 32.48,
  "end": 37.82,
  "dur": 5.34,
  "nchars": 20,
  "text": "智于四圣谛知我已知等不应更知等如次尽无生",
  "flag": ""
 },
 {
  "id": "智-8",
  "pin": "智品",
  "localNo": 8,
  "globalNo": 511,
  "start": 37.82,
  "end": 43.56,
  "dur": 5.74,
  "nchars": 20,
  "text": "由自性对治行相行相境加行办因圆故建立十智",
  "flag": ""
 },
 {
  "id": "智-9",
  "pin": "智品",
  "localNo": 9,
  "globalNo": 512,
  "start": 43.56,
  "end": 48.64,
  "dur": 5.08,
  "nchars": 20,
  "text": "缘灭道法智于修道位中兼治上修断类无能治欲",
  "flag": ""
 },
 {
  "id": "智-10",
  "pin": "智品",
  "localNo": 10,
  "globalNo": 513,
  "start": 48.64,
  "end": 54.08,
  "dur": 5.44,
  "nchars": 20,
  "text": "法智及类智行相俱十六世俗此及余四谛智各四",
  "flag": ""
 },
 {
  "id": "智-11",
  "pin": "智品",
  "localNo": 11,
  "globalNo": 514,
  "start": 54.08,
  "end": 59.6,
  "dur": 5.52,
  "nchars": 20,
  "text": "他心智无漏唯四谓缘道有漏自相缘俱但缘一事",
  "flag": ""
 },
 {
  "id": "智-12",
  "pin": "智品",
  "localNo": 12,
  "globalNo": 515,
  "start": 59.6,
  "end": 65.04,
  "dur": 5.44,
  "nchars": 20,
  "text": "尽无生十四谓离空非我净无越十六余说有论故",
  "flag": ""
 },
 {
  "id": "智-13",
  "pin": "智品",
  "localNo": 13,
  "globalNo": 516,
  "start": 65.04,
  "end": 70.46,
  "dur": 5.42,
  "nchars": 20,
  "text": "行相实十六此体唯是慧能行有所缘所行诸有法",
  "flag": ""
 },
 {
  "id": "智-14",
  "pin": "智品",
  "localNo": 14,
  "globalNo": 517,
  "start": 70.46,
  "end": 75.92,
  "dur": 5.46,
  "nchars": 20,
  "text": "性俗三九善依地俗一切他心智唯四法六余七九",
  "flag": ""
 },
 {
  "id": "智-15",
  "pin": "智品",
  "localNo": 15,
  "globalNo": 518,
  "start": 75.92,
  "end": 81.28,
  "dur": 5.36,
  "nchars": 20,
  "text": "现起所依身他心依欲色法智但依欲余八通三界",
  "flag": ""
 },
 {
  "id": "智-16",
  "pin": "智品",
  "localNo": 16,
  "globalNo": 519,
  "start": 81.28,
  "end": 86.62,
  "dur": 5.34,
  "nchars": 20,
  "text": "诸智念住摄灭智唯最后他心智后三余八智通四",
  "flag": ""
 },
 {
  "id": "智-17",
  "pin": "智品",
  "localNo": 17,
  "globalNo": 520,
  "start": 86.62,
  "end": 92.06,
  "dur": 5.44,
  "nchars": 20,
  "text": "诸智互相缘法类道各九苦集智各二四皆十灭非",
  "flag": ""
 },
 {
  "id": "智-18",
  "pin": "智品",
  "localNo": 18,
  "globalNo": 521,
  "start": 92.06,
  "end": 97.4,
  "dur": 5.34,
  "nchars": 20,
  "text": "所缘总有十谓三界无漏无为各有二俗缘十法五",
  "flag": ""
 },
 {
  "id": "智-19",
  "pin": "智品",
  "localNo": 19,
  "globalNo": 522,
  "start": 97.4,
  "end": 102.7,
  "dur": 5.3,
  "nchars": 20,
  "text": "类七苦集六灭缘一道二他心智缘三尽无生各九",
  "flag": ""
 },
 {
  "id": "智-20",
  "pin": "智品",
  "localNo": 20,
  "globalNo": 523,
  "start": 102.7,
  "end": 108.06,
  "dur": 5.36,
  "nchars": 20,
  "text": "俗智除自品总缘一切法为非我行相唯闻思所成",
  "flag": ""
 },
 {
  "id": "智-21",
  "pin": "智品",
  "localNo": 21,
  "globalNo": 524,
  "start": 108.06,
  "end": 113.44,
  "dur": 5.38,
  "nchars": 20,
  "text": "异生圣见道初念定成一二定成三智后四一一增",
  "flag": ""
 },
 {
  "id": "智-22",
  "pin": "智品",
  "localNo": 22,
  "globalNo": 525,
  "start": 113.44,
  "end": 118.78,
  "dur": 5.34,
  "nchars": 20,
  "text": "修道定成七离欲增他心无学钝利根定成九成十",
  "flag": ""
 },
 {
  "id": "智-23",
  "pin": "智品",
  "localNo": 23,
  "globalNo": 526,
  "start": 118.78,
  "end": 124.22,
  "dur": 5.44,
  "nchars": 20,
  "text": "见道忍智起即彼未来修三类智兼修现观边俗智",
  "flag": ""
 },
 {
  "id": "智-24",
  "pin": "智品",
  "localNo": 24,
  "globalNo": 527,
  "start": 124.22,
  "end": 129.36,
  "dur": 5.14,
  "nchars": 20,
  "text": "不生自下地苦集四灭后自谛行相境唯加行所得",
  "flag": ""
 },
 {
  "id": "智-25",
  "pin": "智品",
  "localNo": 25,
  "globalNo": 528,
  "start": 129.36,
  "end": 134.54,
  "dur": 5.18,
  "nchars": 20,
  "text": "修道初剎那修六或七智断八地无间及有欲余道",
  "flag": ""
 },
 {
  "id": "智-26",
  "pin": "智品",
  "localNo": 26,
  "globalNo": 529,
  "start": 134.54,
  "end": 139.88,
  "dur": 5.34,
  "nchars": 20,
  "text": "有顶八解脱各修于七智上无间余道如次修六八",
  "flag": ""
 },
 {
  "id": "智-27",
  "pin": "智品",
  "localNo": 27,
  "globalNo": 530,
  "start": 139.88,
  "end": 145.2,
  "dur": 5.32,
  "nchars": 20,
  "text": "无学初剎那修九或修十钝利根别故胜进道亦然",
  "flag": ""
 },
 {
  "id": "智-28",
  "pin": "智品",
  "localNo": 28,
  "globalNo": 531,
  "start": 145.2,
  "end": 150.62,
  "dur": 5.42,
  "nchars": 20,
  "text": "练根无间道学六无学七余学六七八应八九一切",
  "flag": ""
 },
 {
  "id": "智-29",
  "pin": "智品",
  "localNo": 29,
  "globalNo": 532,
  "start": 150.85,
  "end": 155.98,
  "dur": 5.13,
  "nchars": 20,
  "text": "杂修通无间学七应八九余道学修八应九或一切",
  "flag": ""
 },
 {
  "id": "智-30",
  "pin": "智品",
  "localNo": 30,
  "globalNo": 533,
  "start": 155.98,
  "end": 161.3,
  "dur": 5.32,
  "nchars": 20,
  "text": "圣起余功德及异生诸位所修智多少皆如理应思",
  "flag": ""
 },
 {
  "id": "智-31",
  "pin": "智品",
  "localNo": 31,
  "globalNo": 534,
  "start": 161.3,
  "end": 166.64,
  "dur": 5.34,
  "nchars": 20,
  "text": "诸道依得此修此地有漏为离得起此修此下无漏",
  "flag": ""
 },
 {
  "id": "智-32",
  "pin": "智品",
  "localNo": 32,
  "globalNo": 535,
  "start": 166.64,
  "end": 172.0,
  "dur": 5.36,
  "nchars": 20,
  "text": "唯初尽遍修九地有漏德生上不修下曾所得非修",
  "flag": ""
 },
 {
  "id": "智-33",
  "pin": "智品",
  "localNo": 33,
  "globalNo": 536,
  "start": 172.0,
  "end": 177.3,
  "dur": 5.3,
  "nchars": 20,
  "text": "立得修习修依善有为法依诸有漏法立治修遣修",
  "flag": ""
 },
 {
  "id": "智-34",
  "pin": "智品",
  "localNo": 34,
  "globalNo": 537,
  "start": 177.3,
  "end": 182.56,
  "dur": 5.26,
  "nchars": 20,
  "text": "十八不共法谓佛十力等力处非处十业八除灭道",
  "flag": ""
 },
 {
  "id": "智-35",
  "pin": "智品",
  "localNo": 35,
  "globalNo": 538,
  "start": 182.56,
  "end": 188.0,
  "dur": 5.44,
  "nchars": 20,
  "text": "定根解界九遍趣九或十宿住死生俗尽六或十智",
  "flag": ""
 },
 {
  "id": "智-36",
  "pin": "智品",
  "localNo": 36,
  "globalNo": 539,
  "start": 188.0,
  "end": 193.42,
  "dur": 5.42,
  "nchars": 20,
  "text": "宿住死生智依静虑余通赡部男佛身于境无碍故",
  "flag": ""
 },
 {
  "id": "智-37",
  "pin": "智品",
  "localNo": 37,
  "globalNo": 540,
  "start": 193.42,
  "end": 198.72,
  "dur": 5.3,
  "nchars": 20,
  "text": "身那罗延力或节节皆然象等七十增此触处为性",
  "flag": ""
 },
 {
  "id": "智-38",
  "pin": "智品",
  "localNo": 38,
  "globalNo": 541,
  "start": 198.94,
  "end": 204.06,
  "dur": 5.12,
  "nchars": 20,
  "text": "四无畏如次初十二七力三念住念慧缘顺违俱境",
  "flag": ""
 },
 {
  "id": "智-39",
  "pin": "智品",
  "localNo": 39,
  "globalNo": 542,
  "start": 204.16,
  "end": 209.54,
  "dur": 5.38,
  "nchars": 20,
  "text": "大悲唯俗智资粮行相境平等上品故异悲由八因",
  "flag": ""
 },
 {
  "id": "智-40",
  "pin": "智品",
  "localNo": 40,
  "globalNo": 543,
  "start": 209.54,
  "end": 214.88,
  "dur": 5.34,
  "nchars": 20,
  "text": "由资粮法身利他佛相似寿种姓量等诸佛有差别",
  "flag": ""
 },
 {
  "id": "智-41",
  "pin": "智品",
  "localNo": 41,
  "globalNo": 544,
  "start": 214.88,
  "end": 220.22,
  "dur": 5.34,
  "nchars": 20,
  "text": "复有余佛法共余圣异生谓无诤愿智无碍解等德",
  "flag": ""
 },
 {
  "id": "智-42",
  "pin": "智品",
  "localNo": 42,
  "globalNo": 545,
  "start": 220.22,
  "end": 225.56,
  "dur": 5.34,
  "nchars": 20,
  "text": "无诤世俗智后静虑不动三洲缘未生欲界有事惑",
  "flag": ""
 },
 {
  "id": "智-43",
  "pin": "智品",
  "localNo": 43,
  "globalNo": 546,
  "start": 225.56,
  "end": 231.16,
  "dur": 5.6,
  "nchars": 20,
  "text": "愿智能遍缘余如无诤说无碍解有四谓法义词辩",
  "flag": ""
 },
 {
  "id": "智-44",
  "pin": "智品",
  "localNo": 44,
  "globalNo": 547,
  "start": 231.16,
  "end": 236.5,
  "dur": 5.34,
  "nchars": 20,
  "text": "名义言说道无退智为性法词唯俗智五二地为依",
  "flag": ""
 },
 {
  "id": "智-45",
  "pin": "智品",
  "localNo": 45,
  "globalNo": 548,
  "start": 236.5,
  "end": 241.86,
  "dur": 5.36,
  "nchars": 20,
  "text": "义十六辩九皆依一切地但得必具四余如无诤说",
  "flag": ""
 },
 {
  "id": "智-46",
  "pin": "智品",
  "localNo": 46,
  "globalNo": 549,
  "start": 241.86,
  "end": 247.12,
  "dur": 5.26,
  "nchars": 20,
  "text": "六依边际得边际六后定遍顺至究竟佛余加行得",
  "flag": ""
 },
 {
  "id": "智-47",
  "pin": "智品",
  "localNo": 47,
  "globalNo": 550,
  "start": 247.12,
  "end": 252.54,
  "dur": 5.42,
  "nchars": 20,
  "text": "通六谓神境天眼耳他心宿住漏尽通解脱道慧摄",
  "flag": ""
 },
 {
  "id": "智-48",
  "pin": "智品",
  "localNo": 48,
  "globalNo": 551,
  "start": 252.76,
  "end": 257.9,
  "dur": 5.14,
  "nchars": 20,
  "text": "四俗他心五漏尽通如力五依四静虑自下地为境",
  "flag": ""
 },
 {
  "id": "智-49",
  "pin": "智品",
  "localNo": 49,
  "globalNo": 552,
  "start": 258.02,
  "end": 263.2,
  "dur": 5.18,
  "nchars": 20,
  "text": "声闻麟喻佛二三千无数未曾由加行曾修离染得",
  "flag": ""
 },
 {
  "id": "智-50",
  "pin": "智品",
  "localNo": 50,
  "globalNo": 553,
  "start": 263.2,
  "end": 268.56,
  "dur": 5.36,
  "nchars": 20,
  "text": "念住初三身他心三余四天眼耳无记余四通唯善",
  "flag": ""
 },
 {
  "id": "智-51",
  "pin": "智品",
  "localNo": 51,
  "globalNo": 554,
  "start": 268.56,
  "end": 273.86,
  "dur": 5.3,
  "nchars": 20,
  "text": "第五二六明治三际愚故后真二假说学有暗非明",
  "flag": ""
 },
 {
  "id": "智-52",
  "pin": "智品",
  "localNo": 52,
  "globalNo": 555,
  "start": 273.86,
  "end": 279.2,
  "dur": 5.34,
  "nchars": 20,
  "text": "第一四六导教诫导为尊定由通所成引利乐果故",
  "flag": ""
 },
 {
  "id": "智-53",
  "pin": "智品",
  "localNo": 53,
  "globalNo": 556,
  "start": 279.2,
  "end": 284.58,
  "dur": 5.38,
  "nchars": 20,
  "text": "神体谓等持境二谓行化行三意势佛运身胜解通",
  "flag": ""
 },
 {
  "id": "智-54",
  "pin": "智品",
  "localNo": 54,
  "globalNo": 557,
  "start": 284.58,
  "end": 289.88,
  "dur": 5.3,
  "nchars": 20,
  "text": "化二谓欲色四二外处性此各有二种谓似自他身",
  "flag": ""
 },
 {
  "id": "智-55",
  "pin": "智品",
  "localNo": 55,
  "globalNo": 558,
  "start": 289.88,
  "end": 295.18,
  "dur": 5.3,
  "nchars": 20,
  "text": "能化心十四定果二至五如所依定得从净自生二",
  "flag": ""
 },
 {
  "id": "智-56",
  "pin": "智品",
  "localNo": 56,
  "globalNo": 559,
  "start": 295.18,
  "end": 300.52,
  "dur": 5.34,
  "nchars": 20,
  "text": "化事由自地语通由自下化身与化主语必俱非佛",
  "flag": ""
 },
 {
  "id": "智-57",
  "pin": "智品",
  "localNo": 57,
  "globalNo": 560,
  "start": 300.52,
  "end": 305.92,
  "dur": 5.4,
  "nchars": 20,
  "text": "先立愿留身后起余心语有死留坚体余说无留义",
  "flag": ""
 },
 {
  "id": "智-58",
  "pin": "智品",
  "localNo": 58,
  "globalNo": 561,
  "start": 305.92,
  "end": 311.34,
  "dur": 5.42,
  "nchars": 20,
  "text": "初多心一化成满此相违修得无记摄余得通三性",
  "flag": ""
 },
 {
  "id": "智-59",
  "pin": "智品",
  "localNo": 59,
  "globalNo": 562,
  "start": 311.34,
  "end": 316.7,
  "dur": 5.36,
  "nchars": 20,
  "text": "天眼耳谓根即定地净色恒同分无缺取障细远等",
  "flag": ""
 },
 {
  "id": "智-60",
  "pin": "智品",
  "localNo": 60,
  "globalNo": 563,
  "start": 316.7,
  "end": 322.0,
  "dur": 5.3,
  "nchars": 20,
  "text": "神境五修生咒药业成故他心修生咒又加占相成",
  "flag": ""
 },
 {
  "id": "智-61",
  "pin": "智品",
  "localNo": 61,
  "globalNo": 564,
  "start": 322.0,
  "end": 327.32,
  "dur": 5.32,
  "nchars": 20,
  "text": "三修生业成除修皆三性人唯无生得地狱初能知",
  "flag": ""
 }
]