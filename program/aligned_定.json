[
 {
  "id": "定-1",
  "pin": "定品",
  "localNo": 1,
  "globalNo": 565,
  "start": 0.0,
  "end": 5.38,
  "dur": 5.38,
  "nchars": 20,
  "text": "静虑四各二于中生已说定谓善一境并伴五蕴性",
  "flag": ""
 },
 {
  "id": "定-2",
  "pin": "定品",
  "localNo": 2,
  "globalNo": 566,
  "start": 5.38,
  "end": 10.82,
  "dur": 5.44,
  "nchars": 20,
  "text": "初具伺喜乐后渐离前支无色亦如是四蕴离下地",
  "flag": ""
 },
 {
  "id": "定-3",
  "pin": "定品",
  "localNo": 3,
  "globalNo": 567,
  "start": 10.82,
  "end": 16.22,
  "dur": 5.4,
  "nchars": 20,
  "text": "并上三近分总名除色想无色谓无色后色起从心",
  "flag": ""
 },
 {
  "id": "定-4",
  "pin": "定品",
  "localNo": 4,
  "globalNo": 568,
  "start": 16.22,
  "end": 21.56,
  "dur": 5.34,
  "nchars": 20,
  "text": "空无边等三名从加行立非想非非想昧劣故立名",
  "flag": ""
 },
 {
  "id": "定-5",
  "pin": "定品",
  "localNo": 5,
  "globalNo": 569,
  "start": 21.56,
  "end": 26.92,
  "dur": 5.36,
  "nchars": 20,
  "text": "此本等至八前七各有三谓味净无漏后味净二种",
  "flag": ""
 },
 {
  "id": "定-6",
  "pin": "定品",
  "localNo": 6,
  "globalNo": 570,
  "start": 26.92,
  "end": 32.22,
  "dur": 5.3,
  "nchars": 20,
  "text": "味谓爱相应净谓世间善此即所味着无漏谓出世",
  "flag": ""
 },
 {
  "id": "定-7",
  "pin": "定品",
  "localNo": 7,
  "globalNo": 571,
  "start": 32.22,
  "end": 37.48,
  "dur": 5.26,
  "nchars": 20,
  "text": "静虑初五支寻伺喜乐定第二有四支内净喜乐定",
  "flag": ""
 },
 {
  "id": "定-8",
  "pin": "定品",
  "localNo": 8,
  "globalNo": 572,
  "start": 37.48,
  "end": 42.72,
  "dur": 5.24,
  "nchars": 20,
  "text": "第三具五支舍念慧乐定第四有四支舍念中受定",
  "flag": ""
 },
 {
  "id": "定-9",
  "pin": "定品",
  "localNo": 9,
  "globalNo": 573,
  "start": 42.72,
  "end": 48.0,
  "dur": 5.28,
  "nchars": 20,
  "text": "此实事十一初二乐轻安内净即信根喜即是喜受",
  "flag": ""
 },
 {
  "id": "定-10",
  "pin": "定品",
  "localNo": 10,
  "globalNo": 574,
  "start": 48.0,
  "end": 53.34,
  "dur": 5.34,
  "nchars": 20,
  "text": "染如次从初无喜乐内净正念慧舍念余说无安舍",
  "flag": ""
 },
 {
  "id": "定-11",
  "pin": "定品",
  "localNo": 11,
  "globalNo": 575,
  "start": 53.34,
  "end": 58.6,
  "dur": 5.26,
  "nchars": 20,
  "text": "第四名不动离八灾患故八者谓寻伺四受入出息",
  "flag": ""
 },
 {
  "id": "定-12",
  "pin": "定品",
  "localNo": 12,
  "globalNo": 576,
  "start": 58.74,
  "end": 64.12,
  "dur": 5.38,
  "nchars": 20,
  "text": "生静虑从初有喜乐舍受及喜舍乐舍唯舍受如次",
  "flag": ""
 },
 {
  "id": "定-13",
  "pin": "定品",
  "localNo": 13,
  "globalNo": 577,
  "start": 64.12,
  "end": 69.4,
  "dur": 5.28,
  "nchars": 20,
  "text": "生上三静虑起三识表心皆初静虑摄唯无覆无记",
  "flag": ""
 },
 {
  "id": "定-14",
  "pin": "定品",
  "localNo": 14,
  "globalNo": 578,
  "start": 69.56,
  "end": 74.9,
  "dur": 5.34,
  "nchars": 20,
  "text": "全不成而得净由离染生无漏由离染染由生及退",
  "flag": ""
 },
 {
  "id": "定-15",
  "pin": "定品",
  "localNo": 15,
  "globalNo": 579,
  "start": 74.9,
  "end": 80.22,
  "dur": 5.32,
  "nchars": 20,
  "text": "无漏次生善上下至第三净次生亦然兼生自地染",
  "flag": ""
 },
 {
  "id": "定-16",
  "pin": "定品",
  "localNo": 16,
  "globalNo": 580,
  "start": 80.22,
  "end": 85.6,
  "dur": 5.38,
  "nchars": 20,
  "text": "染生自净染并下一地净死净生一切染生自下染",
  "flag": ""
 },
 {
  "id": "定-17",
  "pin": "定品",
  "localNo": 17,
  "globalNo": 581,
  "start": 85.6,
  "end": 90.94,
  "dur": 5.34,
  "nchars": 20,
  "text": "净定有四种谓即顺退分顺住顺胜进顺决择分摄",
  "flag": ""
 },
 {
  "id": "定-18",
  "pin": "定品",
  "localNo": 18,
  "globalNo": 582,
  "start": 90.94,
  "end": 96.24,
  "dur": 5.3,
  "nchars": 20,
  "text": "如次顺烦恼自上地无漏互相望如次生二三三一",
  "flag": ""
 },
 {
  "id": "定-19",
  "pin": "定品",
  "localNo": 19,
  "globalNo": 583,
  "start": 96.24,
  "end": 101.62,
  "dur": 5.38,
  "nchars": 20,
  "text": "二类定顺逆均间次及超至间超为成三洲利无学",
  "flag": ""
 },
 {
  "id": "定-20",
  "pin": "定品",
  "localNo": 20,
  "globalNo": 584,
  "start": 101.62,
  "end": 107.02,
  "dur": 5.4,
  "nchars": 20,
  "text": "诸定依自下非上无用故唯生有顶圣起下尽余惑",
  "flag": ""
 },
 {
  "id": "定-21",
  "pin": "定品",
  "localNo": 21,
  "globalNo": 585,
  "start": 107.02,
  "end": 112.36,
  "dur": 5.34,
  "nchars": 20,
  "text": "味定缘自系净无漏遍缘根本善无色不缘下有漏",
  "flag": ""
 },
 {
  "id": "定-22",
  "pin": "定品",
  "localNo": 22,
  "globalNo": 586,
  "start": 112.55,
  "end": 117.52,
  "dur": 4.97,
  "nchars": 20,
  "text": "无漏能断惑及诸净近分近分八舍净初亦圣或三",
  "flag": ""
 },
 {
  "id": "定-23",
  "pin": "定品",
  "localNo": 23,
  "globalNo": 587,
  "start": 117.52,
  "end": 122.78,
  "dur": 5.26,
  "nchars": 20,
  "text": "中静虑无寻具三唯舍受初下有寻伺中唯伺上无",
  "flag": ""
 },
 {
  "id": "定-24",
  "pin": "定品",
  "localNo": 24,
  "globalNo": 588,
  "start": 122.78,
  "end": 128.06,
  "dur": 5.28,
  "nchars": 20,
  "text": "空谓空非我无相谓灭四无愿谓余十谛行相相应",
  "flag": ""
 },
 {
  "id": "定-25",
  "pin": "定品",
  "localNo": 25,
  "globalNo": 589,
  "start": 128.06,
  "end": 133.3,
  "dur": 5.24,
  "nchars": 20,
  "text": "此通净无漏无漏三脱门重二缘无学取空非常相",
  "flag": ""
 },
 {
  "id": "定-26",
  "pin": "定品",
  "localNo": 26,
  "globalNo": 590,
  "start": 133.3,
  "end": 138.6,
  "dur": 5.3,
  "nchars": 20,
  "text": "后缘无相定非择灭为静有漏人不时离上七近分",
  "flag": ""
 },
 {
  "id": "定-27",
  "pin": "定品",
  "localNo": 27,
  "globalNo": 591,
  "start": 138.6,
  "end": 143.88,
  "dur": 5.28,
  "nchars": 20,
  "text": "为得现法乐修诸善静虑为得胜知见修净天眼通",
  "flag": ""
 },
 {
  "id": "定-28",
  "pin": "定品",
  "localNo": 28,
  "globalNo": 592,
  "start": 143.88,
  "end": 149.1,
  "dur": 5.22,
  "nchars": 20,
  "text": "为得分别慧修诸加行善为得诸漏尽修金刚喻定",
  "flag": ""
 },
 {
  "id": "定-29",
  "pin": "定品",
  "localNo": 29,
  "globalNo": 593,
  "start": 149.1,
  "end": 154.3,
  "dur": 5.2,
  "nchars": 20,
  "text": "无量有四种对治瞋等故慈悲无瞋性喜喜舍无贪",
  "flag": ""
 },
 {
  "id": "定-30",
  "pin": "定品",
  "localNo": 30,
  "globalNo": 594,
  "start": 154.48,
  "end": 159.64,
  "dur": 5.16,
  "nchars": 20,
  "text": "此行相如次与乐及拔苦欣慰有情等缘欲界有情",
  "flag": ""
 },
 {
  "id": "定-31",
  "pin": "定品",
  "localNo": 31,
  "globalNo": 595,
  "start": 159.64,
  "end": 164.88,
  "dur": 5.24,
  "nchars": 20,
  "text": "喜初二静虑余六或五十不能断诸惑人起定成三",
  "flag": ""
 },
 {
  "id": "定-32",
  "pin": "定品",
  "localNo": 32,
  "globalNo": 596,
  "start": 164.88,
  "end": 170.16,
  "dur": 5.28,
  "nchars": 20,
  "text": "解脱有八种前三无贪性二二一一定四无色定善",
  "flag": ""
 },
 {
  "id": "定-33",
  "pin": "定品",
  "localNo": 33,
  "globalNo": 597,
  "start": 170.38,
  "end": 175.42,
  "dur": 5.04,
  "nchars": 20,
  "text": "灭受想解脱微微无间生由自地净心及下无漏出",
  "flag": ""
 },
 {
  "id": "定-34",
  "pin": "定品",
  "localNo": 34,
  "globalNo": 598,
  "start": 175.42,
  "end": 180.68,
  "dur": 5.26,
  "nchars": 20,
  "text": "三境欲可见四境类品道自上苦集灭非择灭虚空",
  "flag": ""
 },
 {
  "id": "定-35",
  "pin": "定品",
  "localNo": 35,
  "globalNo": 599,
  "start": 180.68,
  "end": 185.78,
  "dur": 5.1,
  "nchars": 20,
  "text": "胜处有八种二如初解脱次二如第二后四如第三",
  "flag": ""
 },
 {
  "id": "定-36",
  "pin": "定品",
  "localNo": 36,
  "globalNo": 600,
  "start": 185.78,
  "end": 191.2,
  "dur": 5.42,
  "nchars": 20,
  "text": "遍处有十种八如净解脱后二净无色缘自地四蕴",
  "flag": ""
 },
 {
  "id": "定-37",
  "pin": "定品",
  "localNo": 37,
  "globalNo": 601,
  "start": 191.2,
  "end": 196.58,
  "dur": 5.38,
  "nchars": 20,
  "text": "灭定如先辨余皆通二得无色依三界余唯人趣起",
  "flag": ""
 },
 {
  "id": "定-38",
  "pin": "定品",
  "localNo": 38,
  "globalNo": 602,
  "start": 196.58,
  "end": 201.86,
  "dur": 5.28,
  "nchars": 20,
  "text": "二界由因业能起无色定色界起静虑亦由法尔力",
  "flag": ""
 },
 {
  "id": "定-39",
  "pin": "定品",
  "localNo": 39,
  "globalNo": 603,
  "start": 201.86,
  "end": 207.22,
  "dur": 5.36,
  "nchars": 20,
  "text": "佛正法有二谓教证为体有持说行者此便住世间",
  "flag": ""
 }
]