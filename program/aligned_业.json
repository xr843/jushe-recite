[
 {
  "id": "业-1",
  "pin": "业品",
  "localNo": 1,
  "globalNo": 221,
  "start": 0.0,
  "end": 5.64,
  "dur": 5.64,
  "nchars": 20,
  "text": "世别由业生思及思所作思即是意业所作谓身语",
  "flag": ""
 },
 {
  "id": "业-2",
  "pin": "业品",
  "localNo": 2,
  "globalNo": 222,
  "start": 5.64,
  "end": 11.08,
  "dur": 5.44,
  "nchars": 20,
  "text": "此身语二业俱表无表性身表许别形非行动为体",
  "flag": ""
 },
 {
  "id": "业-3",
  "pin": "业品",
  "localNo": 3,
  "globalNo": 223,
  "start": 11.08,
  "end": 16.6,
  "dur": 5.52,
  "nchars": 20,
  "text": "以诸有为法有剎那尽故应无无因故生因应能灭",
  "flag": ""
 },
 {
  "id": "业-4",
  "pin": "业品",
  "localNo": 4,
  "globalNo": 224,
  "start": 16.6,
  "end": 22.0,
  "dur": 5.4,
  "nchars": 20,
  "text": "形亦非实有应二根取故无别极微故语表许言声",
  "flag": ""
 },
 {
  "id": "业-5",
  "pin": "业品",
  "localNo": 5,
  "globalNo": 225,
  "start": 22.0,
  "end": 27.52,
  "dur": 5.52,
  "nchars": 20,
  "text": "说三无漏色增非作等故此能造大种异于表所依",
  "flag": ""
 },
 {
  "id": "业-6",
  "pin": "业品",
  "localNo": 6,
  "globalNo": 226,
  "start": 27.52,
  "end": 32.92,
  "dur": 5.4,
  "nchars": 20,
  "text": "欲后念无表依过大种生有漏自地依无漏随生处",
  "flag": ""
 },
 {
  "id": "业-7",
  "pin": "业品",
  "localNo": 7,
  "globalNo": 227,
  "start": 32.92,
  "end": 38.34,
  "dur": 5.42,
  "nchars": 20,
  "text": "无表无执受亦等流情数散依等流性有受异大生",
  "flag": ""
 },
 {
  "id": "业-8",
  "pin": "业品",
  "localNo": 8,
  "globalNo": 228,
  "start": 38.34,
  "end": 43.76,
  "dur": 5.42,
  "nchars": 20,
  "text": "定生依长养无受无异大表唯等流性属身有执受",
  "flag": ""
 },
 {
  "id": "业-9",
  "pin": "业品",
  "localNo": 9,
  "globalNo": 229,
  "start": 43.76,
  "end": 49.24,
  "dur": 5.48,
  "nchars": 20,
  "text": "无表记余三不善唯在欲无表遍欲色表唯有伺二",
  "flag": ""
 },
 {
  "id": "业-10",
  "pin": "业品",
  "localNo": 10,
  "globalNo": 230,
  "start": 49.24,
  "end": 54.62,
  "dur": 5.38,
  "nchars": 20,
  "text": "欲无有覆表以无等起故胜义善解脱自性惭愧根",
  "flag": ""
 },
 {
  "id": "业-11",
  "pin": "业品",
  "localNo": 11,
  "globalNo": 231,
  "start": 54.62,
  "end": 60.08,
  "dur": 5.46,
  "nchars": 20,
  "text": "相应彼相应等起色业等翻此名不善胜无记二常",
  "flag": ""
 },
 {
  "id": "业-12",
  "pin": "业品",
  "localNo": 12,
  "globalNo": 232,
  "start": 60.08,
  "end": 65.6,
  "dur": 5.52,
  "nchars": 20,
  "text": "等起有二种因及彼剎那如次第应知名转名随转",
  "flag": ""
 },
 {
  "id": "业-13",
  "pin": "业品",
  "localNo": 13,
  "globalNo": 233,
  "start": 65.6,
  "end": 70.88,
  "dur": 5.28,
  "nchars": 20,
  "text": "见断识唯转唯随转五识修断意通二无漏异熟非",
  "flag": ""
 },
 {
  "id": "业-14",
  "pin": "业品",
  "localNo": 14,
  "globalNo": 234,
  "start": 70.88,
  "end": 76.4,
  "dur": 5.52,
  "nchars": 20,
  "text": "于转善等性随转各容三牟尼善必同无记随或善",
  "flag": ""
 },
 {
  "id": "业-15",
  "pin": "业品",
  "localNo": 15,
  "globalNo": 235,
  "start": 76.4,
  "end": 81.84,
  "dur": 5.44,
  "nchars": 20,
  "text": "无表三律仪不律仪非二律仪别解脱静虑及道生",
  "flag": ""
 },
 {
  "id": "业-16",
  "pin": "业品",
  "localNo": 16,
  "globalNo": 236,
  "start": 81.92,
  "end": 87.32,
  "dur": 5.4,
  "nchars": 20,
  "text": "初律仪八种实体唯有四形转名异故各别不相违",
  "flag": ""
 },
 {
  "id": "业-17",
  "pin": "业品",
  "localNo": 17,
  "globalNo": 237,
  "start": 87.32,
  "end": 92.8,
  "dur": 5.48,
  "nchars": 20,
  "text": "受离五八十一切所应离立近事近住勤策及苾刍",
  "flag": ""
 },
 {
  "id": "业-18",
  "pin": "业品",
  "localNo": 18,
  "globalNo": 238,
  "start": 92.8,
  "end": 98.42,
  "dur": 5.62,
  "nchars": 20,
  "text": "俱得名尸罗妙行业律仪唯初表无表名别解业道",
  "flag": ""
 },
 {
  "id": "业-19",
  "pin": "业品",
  "localNo": 19,
  "globalNo": 239,
  "start": 98.42,
  "end": 103.86,
  "dur": 5.44,
  "nchars": 20,
  "text": "八成别解脱得静虑圣者成静虑道生后二随心转",
  "flag": ""
 },
 {
  "id": "业-20",
  "pin": "业品",
  "localNo": 20,
  "globalNo": 240,
  "start": 103.86,
  "end": 109.17,
  "dur": 5.31,
  "nchars": 20,
  "text": "未至九无间俱生二名断正知正念合名意根律仪",
  "flag": ""
 },
 {
  "id": "业-21",
  "pin": "业品",
  "localNo": 21,
  "globalNo": 241,
  "start": 109.34,
  "end": 114.94,
  "dur": 5.6,
  "nchars": 20,
  "text": "住别解无表未舍恒成现剎那后成过不律仪亦然",
  "flag": ""
 },
 {
  "id": "业-22",
  "pin": "业品",
  "localNo": 22,
  "globalNo": 242,
  "start": 114.94,
  "end": 120.44,
  "dur": 5.5,
  "nchars": 20,
  "text": "得静虑律仪恒成就过未圣初除过去住定道成中",
  "flag": ""
 },
 {
  "id": "业-23",
  "pin": "业品",
  "localNo": 23,
  "globalNo": 243,
  "start": 120.44,
  "end": 125.86,
  "dur": 5.42,
  "nchars": 20,
  "text": "住中有无表初成中后二住律不律仪起染净无表",
  "flag": ""
 },
 {
  "id": "业-24",
  "pin": "业品",
  "localNo": 24,
  "globalNo": 244,
  "start": 125.86,
  "end": 131.26,
  "dur": 5.4,
  "nchars": 20,
  "text": "初成中后二至染净势终表正作成中后成过非未",
  "flag": ""
 },
 {
  "id": "业-25",
  "pin": "业品",
  "localNo": 25,
  "globalNo": 245,
  "start": 131.26,
  "end": 136.77,
  "dur": 5.51,
  "nchars": 20,
  "text": "有覆及无覆唯成就现在恶行恶戒业业道不律仪",
  "flag": ""
 },
 {
  "id": "业-26",
  "pin": "业品",
  "localNo": 26,
  "globalNo": 246,
  "start": 136.88,
  "end": 142.32,
  "dur": 5.44,
  "nchars": 20,
  "text": "成表非无表住中劣思作舍未生表圣成无表非表",
  "flag": ""
 },
 {
  "id": "业-27",
  "pin": "业品",
  "localNo": 27,
  "globalNo": 247,
  "start": 142.32,
  "end": 147.72,
  "dur": 5.4,
  "nchars": 20,
  "text": "定生得定地彼圣得道生别解脱律仪得由他教等",
  "flag": ""
 },
 {
  "id": "业-28",
  "pin": "业品",
  "localNo": 28,
  "globalNo": 248,
  "start": 147.72,
  "end": 153.18,
  "dur": 5.46,
  "nchars": 20,
  "text": "别解脱律仪尽寿或昼夜恶戒无昼夜谓非如善受",
  "flag": ""
 },
 {
  "id": "业-29",
  "pin": "业品",
  "localNo": 29,
  "globalNo": 249,
  "start": 153.18,
  "end": 158.7,
  "dur": 5.52,
  "nchars": 20,
  "text": "近住于晨旦下座从师受随教说具支离严饰昼夜",
  "flag": ""
 },
 {
  "id": "业-30",
  "pin": "业品",
  "localNo": 30,
  "globalNo": 250,
  "start": 158.7,
  "end": 164.18,
  "dur": 5.48,
  "nchars": 20,
  "text": "戒不逸禁支四一三如次为防诸性罪失念及骄逸",
  "flag": ""
 },
 {
  "id": "业-31",
  "pin": "业品",
  "localNo": 31,
  "globalNo": 251,
  "start": 164.18,
  "end": 169.64,
  "dur": 5.46,
  "nchars": 20,
  "text": "近住余亦有不受三归无称近事发戒说如苾刍等",
  "flag": ""
 },
 {
  "id": "业-32",
  "pin": "业品",
  "localNo": 32,
  "globalNo": 252,
  "start": 169.64,
  "end": 175.14,
  "dur": 5.5,
  "nchars": 20,
  "text": "若皆具律仪何言一分等谓约能持说下中上随心",
  "flag": ""
 },
 {
  "id": "业-33",
  "pin": "业品",
  "localNo": 33,
  "globalNo": 253,
  "start": 175.14,
  "end": 180.68,
  "dur": 5.54,
  "nchars": 20,
  "text": "归依成佛僧无学二种法及涅槃择灭是说具三归",
  "flag": ""
 },
 {
  "id": "业-34",
  "pin": "业品",
  "localNo": 34,
  "globalNo": 254,
  "start": 180.88,
  "end": 186.04,
  "dur": 5.16,
  "nchars": 20,
  "text": "邪行最可呵易离得不作得律仪如誓非总于相续",
  "flag": ""
 },
 {
  "id": "业-35",
  "pin": "业品",
  "localNo": 35,
  "globalNo": 255,
  "start": 186.2,
  "end": 191.76,
  "dur": 5.56,
  "nchars": 20,
  "text": "以开虚诳语便越诸学处遮中唯离酒为护余律仪",
  "flag": ""
 },
 {
  "id": "业-36",
  "pin": "业品",
  "localNo": 36,
  "globalNo": 256,
  "start": 191.76,
  "end": 197.22,
  "dur": 5.46,
  "nchars": 20,
  "text": "从一切二现得欲界律仪从根本恒时得静虑无漏",
  "flag": ""
 },
 {
  "id": "业-37",
  "pin": "业品",
  "localNo": 37,
  "globalNo": 257,
  "start": 197.22,
  "end": 202.66,
  "dur": 5.44,
  "nchars": 20,
  "text": "律从诸有情支因说不定不律从一切有情支非因",
  "flag": ""
 },
 {
  "id": "业-38",
  "pin": "业品",
  "localNo": 38,
  "globalNo": 258,
  "start": 202.66,
  "end": 208.2,
  "dur": 5.54,
  "nchars": 20,
  "text": "诸得不律仪由作及誓受得所余无表由田受重行",
  "flag": ""
 },
 {
  "id": "业-39",
  "pin": "业品",
  "localNo": 39,
  "globalNo": 259,
  "start": 208.2,
  "end": 213.8,
  "dur": 5.6,
  "nchars": 20,
  "text": "舍别解调伏由故舍命终及二形俱生断善根夜尽",
  "flag": ""
 },
 {
  "id": "业-40",
  "pin": "业品",
  "localNo": 40,
  "globalNo": 260,
  "start": 213.8,
  "end": 219.28,
  "dur": 5.48,
  "nchars": 20,
  "text": "有说由犯重余说由法灭迦湿弥罗说犯二如负财",
  "flag": ""
 },
 {
  "id": "业-41",
  "pin": "业品",
  "localNo": 41,
  "globalNo": 261,
  "start": 219.28,
  "end": 224.74,
  "dur": 5.46,
  "nchars": 20,
  "text": "舍定生善法由易地退等舍圣由得果练根及退失",
  "flag": ""
 },
 {
  "id": "业-42",
  "pin": "业品",
  "localNo": 42,
  "globalNo": 262,
  "start": 224.74,
  "end": 230.28,
  "dur": 5.54,
  "nchars": 20,
  "text": "舍恶戒由死得戒二形生舍中由受势作事寿根断",
  "flag": ""
 },
 {
  "id": "业-43",
  "pin": "业品",
  "localNo": 43,
  "globalNo": 263,
  "start": 230.28,
  "end": 235.74,
  "dur": 5.46,
  "nchars": 20,
  "text": "舍欲非色善由根断上生由对治道生舍诸非色染",
  "flag": ""
 },
 {
  "id": "业-44",
  "pin": "业品",
  "localNo": 44,
  "globalNo": 264,
  "start": 235.74,
  "end": 241.24,
  "dur": 5.5,
  "nchars": 20,
  "text": "恶戒人除北二黄门二形律仪亦在天唯人具三种",
  "flag": ""
 },
 {
  "id": "业-45",
  "pin": "业品",
  "localNo": 45,
  "globalNo": 265,
  "start": 241.24,
  "end": 246.64,
  "dur": 5.4,
  "nchars": 20,
  "text": "生欲天色界有静虑律仪无漏并无色除中定无想",
  "flag": ""
 },
 {
  "id": "业-46",
  "pin": "业品",
  "localNo": 46,
  "globalNo": 266,
  "start": 246.64,
  "end": 252.06,
  "dur": 5.42,
  "nchars": 20,
  "text": "安不安非业名善恶无记福非福不动欲善业名福",
  "flag": ""
 },
 {
  "id": "业-47",
  "pin": "业品",
  "localNo": 47,
  "globalNo": 267,
  "start": 252.06,
  "end": 257.42,
  "dur": 5.36,
  "nchars": 20,
  "text": "不善名非福上界善不动约自地处所业果无动故",
  "flag": ""
 },
 {
  "id": "业-48",
  "pin": "业品",
  "localNo": 48,
  "globalNo": 268,
  "start": 257.42,
  "end": 262.78,
  "dur": 5.36,
  "nchars": 20,
  "text": "顺乐苦非二善至三顺乐诸不善顺苦上善顺非二",
  "flag": ""
 },
 {
  "id": "业-49",
  "pin": "业品",
  "localNo": 49,
  "globalNo": 269,
  "start": 262.78,
  "end": 268.26,
  "dur": 5.48,
  "nchars": 20,
  "text": "余说下亦有由中招异熟又许此三业非前后熟故",
  "flag": ""
 },
 {
  "id": "业-50",
  "pin": "业品",
  "localNo": 50,
  "globalNo": 270,
  "start": 268.26,
  "end": 273.64,
  "dur": 5.38,
  "nchars": 20,
  "text": "顺受总有五谓自性相应及所缘异熟现前差别故",
  "flag": ""
 },
 {
  "id": "业-51",
  "pin": "业品",
  "localNo": 51,
  "globalNo": 271,
  "start": 273.86,
  "end": 279.16,
  "dur": 5.3,
  "nchars": 20,
  "text": "此有定不定定三顺现等或说业有五余师说四句",
  "flag": ""
 },
 {
  "id": "业-52",
  "pin": "业品",
  "localNo": 52,
  "globalNo": 272,
  "start": 279.16,
  "end": 284.56,
  "dur": 5.4,
  "nchars": 20,
  "text": "四善容俱作引同分唯三诸处造四种地狱善除现",
  "flag": ""
 },
 {
  "id": "业-53",
  "pin": "业品",
  "localNo": 53,
  "globalNo": 273,
  "start": 284.56,
  "end": 290.0,
  "dur": 5.44,
  "nchars": 20,
  "text": "坚于离染地异生不造生圣不造生后并欲有顶退",
  "flag": ""
 },
 {
  "id": "业-54",
  "pin": "业品",
  "localNo": 54,
  "globalNo": 274,
  "start": 290.0,
  "end": 295.38,
  "dur": 5.38,
  "nchars": 20,
  "text": "欲中有能造二十二种业皆顺现受摄类同分一故",
  "flag": ""
 },
 {
  "id": "业-55",
  "pin": "业品",
  "localNo": 55,
  "globalNo": 275,
  "start": 295.38,
  "end": 300.9,
  "dur": 5.52,
  "nchars": 20,
  "text": "由重惑净心及是恒所造于功德田起害父母业定",
  "flag": ""
 },
 {
  "id": "业-56",
  "pin": "业品",
  "localNo": 56,
  "globalNo": 276,
  "start": 300.9,
  "end": 306.36,
  "dur": 5.46,
  "nchars": 20,
  "text": "由田意殊胜及定招异熟得永离地业定招现法果",
  "flag": ""
 },
 {
  "id": "业-57",
  "pin": "业品",
  "localNo": 57,
  "globalNo": 277,
  "start": 306.36,
  "end": 311.78,
  "dur": 5.42,
  "nchars": 20,
  "text": "于佛上首僧及灭定无诤慈见修道出损益业即受",
  "flag": ""
 },
 {
  "id": "业-58",
  "pin": "业品",
  "localNo": 58,
  "globalNo": 278,
  "start": 311.78,
  "end": 317.2,
  "dur": 5.42,
  "nchars": 20,
  "text": "诸善无寻业许唯感心受恶唯感身受是感受业异",
  "flag": ""
 },
 {
  "id": "业-59",
  "pin": "业品",
  "localNo": 59,
  "globalNo": 279,
  "start": 317.2,
  "end": 322.62,
  "dur": 5.42,
  "nchars": 20,
  "text": "心狂唯意识由业异熟生及怖害违忧除北洲在欲",
  "flag": ""
 },
 {
  "id": "业-60",
  "pin": "业品",
  "localNo": 60,
  "globalNo": 280,
  "start": 322.62,
  "end": 328.2,
  "dur": 5.58,
  "nchars": 20,
  "text": "说曲秽浊业依谄瞋贪生依黑黑等殊所说四种业",
  "flag": ""
 },
 {
  "id": "业-61",
  "pin": "业品",
  "localNo": 61,
  "globalNo": 281,
  "start": 328.2,
  "end": 333.62,
  "dur": 5.42,
  "nchars": 20,
  "text": "恶色欲界善能尽彼无漏应知如次第名黑白俱非",
  "flag": ""
 },
 {
  "id": "业-62",
  "pin": "业品",
  "localNo": 62,
  "globalNo": 282,
  "start": 333.62,
  "end": 339.18,
  "dur": 5.56,
  "nchars": 20,
  "text": "四法忍离欲前八无间俱十二无漏思唯尽纯黑业",
  "flag": ""
 },
 {
  "id": "业-63",
  "pin": "业品",
  "localNo": 63,
  "globalNo": 283,
  "start": 339.18,
  "end": 344.58,
  "dur": 5.4,
  "nchars": 20,
  "text": "离欲四静虑第九无间思一尽杂纯黑四令纯白尽",
  "flag": ""
 },
 {
  "id": "业-64",
  "pin": "业品",
  "localNo": 64,
  "globalNo": 284,
  "start": 344.58,
  "end": 349.84,
  "dur": 5.26,
  "nchars": 20,
  "text": "有说地狱受余欲业黑杂有说欲见灭余欲业黑俱",
  "flag": ""
 },
 {
  "id": "业-65",
  "pin": "业品",
  "localNo": 65,
  "globalNo": 285,
  "start": 349.84,
  "end": 355.38,
  "dur": 5.54,
  "nchars": 20,
  "text": "无学身语业即意三牟尼三清净应知即诸三妙行",
  "flag": ""
 },
 {
  "id": "业-66",
  "pin": "业品",
  "localNo": 66,
  "globalNo": 286,
  "start": 355.38,
  "end": 360.86,
  "dur": 5.48,
  "nchars": 20,
  "text": "恶身语意业说名三恶行及贪瞋邪见三妙行翻此",
  "flag": ""
 },
 {
  "id": "业-67",
  "pin": "业品",
  "localNo": 67,
  "globalNo": 287,
  "start": 360.86,
  "end": 366.56,
  "dur": 5.7,
  "nchars": 20,
  "text": "所说十业道摄恶妙行中粗品为其性如应成善恶",
  "flag": ""
 },
 {
  "id": "业-68",
  "pin": "业品",
  "localNo": 68,
  "globalNo": 288,
  "start": 366.56,
  "end": 371.88,
  "dur": 5.32,
  "nchars": 20,
  "text": "恶六定无表彼自作淫二善七受生二定生唯无表",
  "flag": ""
 },
 {
  "id": "业-69",
  "pin": "业品",
  "localNo": 69,
  "globalNo": 289,
  "start": 371.88,
  "end": 377.28,
  "dur": 5.4,
  "nchars": 20,
  "text": "加行定有表无表或有无后起此相违加行三根起",
  "flag": ""
 },
 {
  "id": "业-70",
  "pin": "业品",
  "localNo": 70,
  "globalNo": 290,
  "start": 377.42,
  "end": 382.67,
  "dur": 5.25,
  "nchars": 20,
  "text": "彼无间生故贪等三根生善于三位中皆三善根起",
  "flag": ""
 },
 {
  "id": "业-71",
  "pin": "业品",
  "localNo": 71,
  "globalNo": 291,
  "start": 382.82,
  "end": 388.2,
  "dur": 5.38,
  "nchars": 20,
  "text": "杀粗语瞋恚究竟皆由瞋盗邪行及贪皆由贪究竟",
  "flag": ""
 },
 {
  "id": "业-72",
  "pin": "业品",
  "localNo": 72,
  "globalNo": 292,
  "start": 388.2,
  "end": 393.4,
  "dur": 5.2,
  "nchars": 20,
  "text": "邪见痴究竟许所余由三有情具名色名身等处起",
  "flag": ""
 },
 {
  "id": "业-73",
  "pin": "业品",
  "localNo": 73,
  "globalNo": 293,
  "start": 393.58,
  "end": 399.02,
  "dur": 5.44,
  "nchars": 20,
  "text": "俱死及前死无根依别故军等若同事皆成如作者",
  "flag": ""
 },
 {
  "id": "业-74",
  "pin": "业品",
  "localNo": 74,
  "globalNo": 294,
  "start": 399.02,
  "end": 404.52,
  "dur": 5.5,
  "nchars": 20,
  "text": "杀生由故思他想不误杀不与取他物力窃取属己",
  "flag": ""
 },
 {
  "id": "业-75",
  "pin": "业品",
  "localNo": 75,
  "globalNo": 295,
  "start": 404.52,
  "end": 409.92,
  "dur": 5.4,
  "nchars": 20,
  "text": "欲邪行四种行所不应行染异想发言解义虚诳语",
  "flag": ""
 },
 {
  "id": "业-76",
  "pin": "业品",
  "localNo": 76,
  "globalNo": 296,
  "start": 409.92,
  "end": 415.44,
  "dur": 5.52,
  "nchars": 20,
  "text": "由眼耳意识并余三所证如次第名为所见闻知觉",
  "flag": ""
 },
 {
  "id": "业-77",
  "pin": "业品",
  "localNo": 77,
  "globalNo": 297,
  "start": 415.69,
  "end": 420.96,
  "dur": 5.27,
  "nchars": 20,
  "text": "染心坏他语说名离间语非爱粗恶语诸染杂秽语",
  "flag": ""
 },
 {
  "id": "业-78",
  "pin": "业品",
  "localNo": 78,
  "globalNo": 298,
  "start": 420.96,
  "end": 426.2,
  "dur": 5.24,
  "nchars": 20,
  "text": "余说异三染佞歌邪论等恶欲他财贪憎有情瞋恚",
  "flag": ""
 },
 {
  "id": "业-79",
  "pin": "业品",
  "localNo": 79,
  "globalNo": 299,
  "start": 426.39,
  "end": 431.58,
  "dur": 5.19,
  "nchars": 20,
  "text": "拨善恶等见名邪见业道此中三唯道七业亦道故",
  "flag": ""
 },
 {
  "id": "业-80",
  "pin": "业品",
  "localNo": 80,
  "globalNo": 300,
  "start": 431.58,
  "end": 437.06,
  "dur": 5.48,
  "nchars": 20,
  "text": "唯邪见断善所断欲生得拨因果一切渐断二俱舍",
  "flag": ""
 },
 {
  "id": "业-81",
  "pin": "业品",
  "localNo": 81,
  "globalNo": 301,
  "start": 437.06,
  "end": 442.5,
  "dur": 5.44,
  "nchars": 20,
  "text": "人三洲男女见行断非得续善疑有见顿现除逆者",
  "flag": ""
 },
 {
  "id": "业-82",
  "pin": "业品",
  "localNo": 82,
  "globalNo": 302,
  "start": 442.5,
  "end": 447.86,
  "dur": 5.36,
  "nchars": 20,
  "text": "业道思俱转不善一至八善总开至十别遮一八五",
  "flag": ""
 },
 {
  "id": "业-83",
  "pin": "业品",
  "localNo": 83,
  "globalNo": 303,
  "start": 447.86,
  "end": 453.22,
  "dur": 5.36,
  "nchars": 20,
  "text": "不善地狱中粗杂瞋通二贪邪见成就北洲成后三",
  "flag": ""
 },
 {
  "id": "业-84",
  "pin": "业品",
  "localNo": 84,
  "globalNo": 304,
  "start": 453.22,
  "end": 458.7,
  "dur": 5.48,
  "nchars": 20,
  "text": "杂语通现成余欲十通二善于一切处后三通现成",
  "flag": ""
 },
 {
  "id": "业-85",
  "pin": "业品",
  "localNo": 85,
  "globalNo": 305,
  "start": 458.7,
  "end": 464.16,
  "dur": 5.46,
  "nchars": 20,
  "text": "无色无想天前七唯成就余处通成现除地狱北洲",
  "flag": ""
 },
 {
  "id": "业-86",
  "pin": "业品",
  "localNo": 86,
  "globalNo": 306,
  "start": 464.16,
  "end": 469.56,
  "dur": 5.4,
  "nchars": 20,
  "text": "皆能招异熟等流增上果此令他受苦断命坏威故",
  "flag": ""
 },
 {
  "id": "业-87",
  "pin": "业品",
  "localNo": 87,
  "globalNo": 307,
  "start": 469.56,
  "end": 474.94,
  "dur": 5.38,
  "nchars": 20,
  "text": "贪生身语业邪命难除故执命资贪生违经故非理",
  "flag": ""
 },
 {
  "id": "业-88",
  "pin": "业品",
  "localNo": 88,
  "globalNo": 308,
  "start": 474.94,
  "end": 480.3,
  "dur": 5.36,
  "nchars": 20,
  "text": "断道有漏业具足有五果无漏业有四谓唯除异熟",
  "flag": ""
 },
 {
  "id": "业-89",
  "pin": "业品",
  "localNo": 89,
  "globalNo": 309,
  "start": 480.3,
  "end": 485.72,
  "dur": 5.42,
  "nchars": 20,
  "text": "余有漏善恶亦四除离系余无漏无记三除前所除",
  "flag": ""
 },
 {
  "id": "业-90",
  "pin": "业品",
  "localNo": 90,
  "globalNo": 310,
  "start": 485.72,
  "end": 491.06,
  "dur": 5.34,
  "nchars": 20,
  "text": "善等于善等初有四二三中有二三四后二三三果",
  "flag": ""
 },
 {
  "id": "业-91",
  "pin": "业品",
  "localNo": 91,
  "globalNo": 311,
  "start": 491.06,
  "end": 496.5,
  "dur": 5.44,
  "nchars": 20,
  "text": "过于三各四现于未亦尔现于现二果未于未果三",
  "flag": ""
 },
 {
  "id": "业-92",
  "pin": "业品",
  "localNo": 92,
  "globalNo": 312,
  "start": 496.5,
  "end": 501.92,
  "dur": 5.42,
  "nchars": 20,
  "text": "同地有四果异地二或三学于三各三无学一三二",
  "flag": ""
 },
 {
  "id": "业-93",
  "pin": "业品",
  "localNo": 93,
  "globalNo": 313,
  "start": 501.92,
  "end": 507.32,
  "dur": 5.4,
  "nchars": 20,
  "text": "非学非无学有二二五果见所断业等一一各于三",
  "flag": ""
 },
 {
  "id": "业-94",
  "pin": "业品",
  "localNo": 94,
  "globalNo": 314,
  "start": 507.32,
  "end": 512.7,
  "dur": 5.38,
  "nchars": 20,
  "text": "初有三四一中二四三果后有一二四皆如次应知",
  "flag": ""
 },
 {
  "id": "业-95",
  "pin": "业品",
  "localNo": 95,
  "globalNo": 315,
  "start": 512.7,
  "end": 518.0,
  "dur": 5.3,
  "nchars": 20,
  "text": "染业不应作有说亦坏轨应作业翻此俱相违第三",
  "flag": ""
 },
 {
  "id": "业-96",
  "pin": "业品",
  "localNo": 96,
  "globalNo": 316,
  "start": 518.4,
  "end": 523.54,
  "dur": 5.14,
  "nchars": 20,
  "text": "一业引一生多业能圆满二无心定得不能引余通",
  "flag": ""
 },
 {
  "id": "业-97",
  "pin": "业品",
  "localNo": 97,
  "globalNo": 317,
  "start": 523.54,
  "end": 528.92,
  "dur": 5.38,
  "nchars": 20,
  "text": "三障无间业及数行烦恼并一切恶趣北洲无想天",
  "flag": ""
 },
 {
  "id": "业-98",
  "pin": "业品",
  "localNo": 98,
  "globalNo": 318,
  "start": 528.92,
  "end": 534.28,
  "dur": 5.36,
  "nchars": 20,
  "text": "三洲有无间非余扇搋等少恩少羞耻余障通五趣",
  "flag": ""
 },
 {
  "id": "业-99",
  "pin": "业品",
  "localNo": 99,
  "globalNo": 319,
  "start": 534.28,
  "end": 539.88,
  "dur": 5.6,
  "nchars": 20,
  "text": "此五无间中四身一语业三杀一诳语一杀生加行",
  "flag": ""
 },
 {
  "id": "业-100",
  "pin": "业品",
  "localNo": 100,
  "globalNo": 320,
  "start": 539.88,
  "end": 545.18,
  "dur": 5.3,
  "nchars": 20,
  "text": "僧破不和合心不相应行无覆无记性所破僧所成",
  "flag": ""
 },
 {
  "id": "业-101",
  "pin": "业品",
  "localNo": 101,
  "globalNo": 321,
  "start": 545.18,
  "end": 550.74,
  "dur": 5.56,
  "nchars": 20,
  "text": "能破者唯成此虚诳语罪无间一劫熟随罪增苦增",
  "flag": ""
 },
 {
  "id": "业-102",
  "pin": "业品",
  "localNo": 102,
  "globalNo": 322,
  "start": 550.74,
  "end": 555.96,
  "dur": 5.22,
  "nchars": 20,
  "text": "苾刍见净行破异处愚夫忍异师道时名破不经宿",
  "flag": ""
 },
 {
  "id": "业-103",
  "pin": "业品",
  "localNo": 103,
  "globalNo": 323,
  "start": 556.19,
  "end": 561.36,
  "dur": 5.17,
  "nchars": 20,
  "text": "赡部洲九等方破法轮僧唯破羯磨僧通三洲八等",
  "flag": ""
 },
 {
  "id": "业-104",
  "pin": "业品",
  "localNo": 104,
  "globalNo": 324,
  "start": 561.36,
  "end": 567.06,
  "dur": 5.7,
  "nchars": 20,
  "text": "初后疱双前佛灭未结界于如是六位无破法轮僧",
  "flag": ""
 },
 {
  "id": "业-105",
  "pin": "业品",
  "localNo": 105,
  "globalNo": 325,
  "start": 567.06,
  "end": 572.2,
  "dur": 5.14,
  "nchars": 20,
  "text": "弃坏恩德田转形亦成逆母谓因彼血误等无或有",
  "flag": ""
 },
 {
  "id": "业-106",
  "pin": "业品",
  "localNo": 106,
  "globalNo": 326,
  "start": 572.2,
  "end": 577.6,
  "dur": 5.4,
  "nchars": 20,
  "text": "打心出佛血害后无学无造逆定加行无离染得果",
  "flag": ""
 },
 {
  "id": "业-107",
  "pin": "业品",
  "localNo": 107,
  "globalNo": 327,
  "start": 577.6,
  "end": 583.04,
  "dur": 5.44,
  "nchars": 20,
  "text": "破僧虚诳语于罪中最大感第一有思世善中大果",
  "flag": ""
 },
 {
  "id": "业-108",
  "pin": "业品",
  "localNo": 108,
  "globalNo": 328,
  "start": 583.04,
  "end": 588.66,
  "dur": 5.62,
  "nchars": 20,
  "text": "污母无学尼杀住定菩萨及有学圣者夺僧和合缘",
  "flag": ""
 },
 {
  "id": "业-109",
  "pin": "业品",
  "localNo": 109,
  "globalNo": 329,
  "start": 588.66,
  "end": 594.08,
  "dur": 5.42,
  "nchars": 20,
  "text": "破坏率堵婆是无间同类将得忍不还无学业为障",
  "flag": ""
 },
 {
  "id": "业-110",
  "pin": "业品",
  "localNo": 110,
  "globalNo": 330,
  "start": 594.08,
  "end": 599.56,
  "dur": 5.48,
  "nchars": 20,
  "text": "从修妙相业菩萨得定名生善趣贵家具男念坚固",
  "flag": ""
 },
 {
  "id": "业-111",
  "pin": "业品",
  "localNo": 111,
  "globalNo": 331,
  "start": 599.77,
  "end": 604.86,
  "dur": 5.09,
  "nchars": 20,
  "text": "赡部男对佛佛思思所成余百劫方修各百福严饰",
  "flag": ""
 },
 {
  "id": "业-112",
  "pin": "业品",
  "localNo": 112,
  "globalNo": 332,
  "start": 604.86,
  "end": 610.34,
  "dur": 5.48,
  "nchars": 20,
  "text": "于三无数劫各供养七万又如次供养五六七千佛",
  "flag": ""
 },
 {
  "id": "业-113",
  "pin": "业品",
  "localNo": 113,
  "globalNo": 333,
  "start": 610.34,
  "end": 615.84,
  "dur": 5.5,
  "nchars": 20,
  "text": "三无数劫满逆次逢胜观燃灯宝髻佛初释迦牟尼",
  "flag": ""
 },
 {
  "id": "业-114",
  "pin": "业品",
  "localNo": 114,
  "globalNo": 334,
  "start": 615.84,
  "end": 621.32,
  "dur": 5.48,
  "nchars": 20,
  "text": "但由悲普施被折身无忿赞叹底沙佛次无上菩提",
  "flag": ""
 },
 {
  "id": "业-115",
  "pin": "业品",
  "localNo": 115,
  "globalNo": 335,
  "start": 621.32,
  "end": 626.76,
  "dur": 5.44,
  "nchars": 20,
  "text": "六波罗蜜多于如是四位一二又一二如次修圆满",
  "flag": ""
 },
 {
  "id": "业-116",
  "pin": "业品",
  "localNo": 116,
  "globalNo": 336,
  "start": 626.76,
  "end": 632.16,
  "dur": 5.4,
  "nchars": 20,
  "text": "施戒修三类各随其所应受福业事名差别如业道",
  "flag": ""
 },
 {
  "id": "业-117",
  "pin": "业品",
  "localNo": 117,
  "globalNo": 337,
  "start": 632.16,
  "end": 637.9,
  "dur": 5.74,
  "nchars": 20,
  "text": "由此舍名施谓为供为益身语及能发此招大富果",
  "flag": ""
 },
 {
  "id": "业-118",
  "pin": "业品",
  "localNo": 118,
  "globalNo": 338,
  "start": 637.9,
  "end": 643.38,
  "dur": 5.48,
  "nchars": 20,
  "text": "为益自他俱不为二行施由主财田异故施果差别",
  "flag": ""
 },
 {
  "id": "业-119",
  "pin": "业品",
  "localNo": 119,
  "globalNo": 339,
  "start": 643.38,
  "end": 648.92,
  "dur": 5.54,
  "nchars": 20,
  "text": "主异由信等行敬重等施得尊重广爱应时难夺果",
  "flag": ""
 },
 {
  "id": "业-120",
  "pin": "业品",
  "localNo": 120,
  "globalNo": 340,
  "start": 648.92,
  "end": 654.42,
  "dur": 5.5,
  "nchars": 20,
  "text": "财异由色等得妙色好名众爱柔软身有随时乐触",
  "flag": ""
 },
 {
  "id": "业-121",
  "pin": "业品",
  "localNo": 121,
  "globalNo": 341,
  "start": 654.42,
  "end": 659.82,
  "dur": 5.4,
  "nchars": 20,
  "text": "田异由趣苦恩德有差别脱于脱菩萨第八施最胜",
  "flag": ""
 },
 {
  "id": "业-122",
  "pin": "业品",
  "localNo": 122,
  "globalNo": 342,
  "start": 659.82,
  "end": 665.24,
  "dur": 5.42,
  "nchars": 20,
  "text": "父母病法师最后身菩萨设非证圣者施果亦无量",
  "flag": ""
 },
 {
  "id": "业-123",
  "pin": "业品",
  "localNo": 123,
  "globalNo": 343,
  "start": 665.24,
  "end": 670.66,
  "dur": 5.42,
  "nchars": 20,
  "text": "后起田根本加行思意乐由此下上故业成下上品",
  "flag": ""
 },
 {
  "id": "业-124",
  "pin": "业品",
  "localNo": 124,
  "globalNo": 344,
  "start": 670.66,
