[
 {
  "id": "世间-1",
  "pin": "世间品",
  "localNo": 1,
  "globalNo": 122,
  "start": 0.0,
  "end": 5.76,
  "dur": 5.76,
  "nchars": 20,
  "text": "地狱傍生鬼人及六欲天名欲界二十由地狱洲异",
  "flag": ""
 },
 {
  "id": "世间-2",
  "pin": "世间品",
  "localNo": 2,
  "globalNo": 123,
  "start": 5.76,
  "end": 11.44,
  "dur": 5.68,
  "nchars": 20,
  "text": "此上十七处名色界于中三静虑各三第四静虑八",
  "flag": ""
 },
 {
  "id": "世间-3",
  "pin": "世间品",
  "localNo": 3,
  "globalNo": 124,
  "start": 11.44,
  "end": 17.14,
  "dur": 5.7,
  "nchars": 20,
  "text": "无色界无处由生有四种依同分及命令心等相续",
  "flag": ""
 },
 {
  "id": "世间-4",
  "pin": "世间品",
  "localNo": 4,
  "globalNo": 125,
  "start": 17.14,
  "end": 22.72,
  "dur": 5.58,
  "nchars": 20,
  "text": "于中地狱等自名说五趣唯无覆无记有情非中有",
  "flag": ""
 },
 {
  "id": "世间-5",
  "pin": "世间品",
  "localNo": 5,
  "globalNo": 126,
  "start": 22.72,
  "end": 28.32,
  "dur": 5.6,
  "nchars": 20,
  "text": "身异及想异身异同一想翻此身想一并无色下三",
  "flag": ""
 },
 {
  "id": "世间-6",
  "pin": "世间品",
  "localNo": 6,
  "globalNo": 127,
  "start": 28.32,
  "end": 34.02,
  "dur": 5.7,
  "nchars": 20,
  "text": "故识住有七余非有损坏应知兼有顶及无想有情",
  "flag": ""
 },
 {
  "id": "世间-7",
  "pin": "世间品",
  "localNo": 7,
  "globalNo": 128,
  "start": 34.02,
  "end": 39.68,
  "dur": 5.66,
  "nchars": 20,
  "text": "是九有情居余非不乐住四识住当知四蕴唯自地",
  "flag": ""
 },
 {
  "id": "世间-8",
  "pin": "世间品",
  "localNo": 8,
  "globalNo": 129,
  "start": 39.68,
  "end": 45.28,
  "dur": 5.6,
  "nchars": 20,
  "text": "说独识非住有漏四句摄于中有四生有情谓卵等",
  "flag": ""
 },
 {
  "id": "世间-9",
  "pin": "世间品",
  "localNo": 9,
  "globalNo": 130,
  "start": 45.28,
  "end": 50.94,
  "dur": 5.66,
  "nchars": 20,
  "text": "人傍生具四地狱及诸天中有唯化生鬼通胎化二",
  "flag": ""
 },
 {
  "id": "世间-10",
  "pin": "世间品",
  "localNo": 10,
  "globalNo": 131,
  "start": 51.13,
  "end": 56.48,
  "dur": 5.35,
  "nchars": 20,
  "text": "死生二有中五蕴名中有未至应至处故中有非生",
  "flag": ""
 },
 {
  "id": "世间-11",
  "pin": "世间品",
  "localNo": 11,
  "globalNo": 132,
  "start": 56.48,
  "end": 62.24,
  "dur": 5.76,
  "nchars": 20,
  "text": "如谷等相续处无间续生像实有不成不等故非譬",
  "flag": ""
 },
 {
  "id": "世间-12",
  "pin": "世间品",
  "localNo": 12,
  "globalNo": 133,
  "start": 62.24,
  "end": 67.76,
  "dur": 5.52,
  "nchars": 20,
  "text": "一处无二并非相续二生说有健达缚及五七经故",
  "flag": ""
 },
 {
  "id": "世间-13",
  "pin": "世间品",
  "localNo": 13,
  "globalNo": 134,
  "start": 67.76,
  "end": 73.34,
  "dur": 5.58,
  "nchars": 20,
  "text": "此一业引故如当本有形本有谓死前居生剎那后",
  "flag": ""
 },
 {
  "id": "世间-14",
  "pin": "世间品",
  "localNo": 14,
  "globalNo": 135,
  "start": 73.34,
  "end": 78.88,
  "dur": 5.54,
  "nchars": 20,
  "text": "同净天眼见业通疾具根无对不可转食香非久住",
  "flag": ""
 },
 {
  "id": "世间-15",
  "pin": "世间品",
  "localNo": 15,
  "globalNo": 136,
  "start": 79.04,
  "end": 84.58,
  "dur": 5.54,
  "nchars": 20,
  "text": "倒心趣欲境湿化染香处天首上三横地狱头归下",
  "flag": ""
 },
 {
  "id": "世间-16",
  "pin": "世间品",
  "localNo": 16,
  "globalNo": 137,
  "start": 84.58,
  "end": 90.16,
  "dur": 5.58,
  "nchars": 20,
  "text": "一于入正知二三兼住出四于一切位及卵恒无知",
  "flag": ""
 },
 {
  "id": "世间-17",
  "pin": "世间品",
  "localNo": 17,
  "globalNo": 138,
  "start": 90.16,
  "end": 95.74,
  "dur": 5.58,
  "nchars": 20,
  "text": "前三种入胎谓轮王二佛业智俱胜故如次四余生",
  "flag": ""
 },
 {
  "id": "世间-18",
  "pin": "世间品",
  "localNo": 18,
  "globalNo": 139,
  "start": 95.74,
  "end": 101.38,
  "dur": 5.64,
  "nchars": 20,
  "text": "无我唯诸蕴烦恼业所为由中有相续入胎如灯焰",
  "flag": ""
 },
 {
  "id": "世间-19",
  "pin": "世间品",
  "localNo": 19,
  "globalNo": 140,
  "start": 101.38,
  "end": 106.92,
  "dur": 5.54,
  "nchars": 20,
  "text": "如引次第增相续由惑业更趣于余世故有轮无初",
  "flag": ""
 },
 {
  "id": "世间-20",
  "pin": "世间品",
  "localNo": 20,
  "globalNo": 141,
  "start": 106.92,
  "end": 112.62,
  "dur": 5.7,
  "nchars": 20,
  "text": "如是诸缘起十二支三际前后际各二中八据圆满",
  "flag": ""
 },
 {
  "id": "世间-21",
  "pin": "世间品",
  "localNo": 21,
  "globalNo": 142,
  "start": 112.62,
  "end": 118.12,
  "dur": 5.5,
  "nchars": 20,
  "text": "宿惑位无明宿诸业名行识正结生蕴六处前名色",
  "flag": ""
 },
 {
  "id": "世间-22",
  "pin": "世间品",
  "localNo": 22,
  "globalNo": 143,
  "start": 118.12,
  "end": 123.74,
  "dur": 5.62,
  "nchars": 20,
  "text": "从生眼等根三和前六处于三受因异未了知名触",
  "flag": ""
 },
 {
  "id": "世间-23",
  "pin": "世间品",
  "localNo": 23,
  "globalNo": 144,
  "start": 123.74,
  "end": 129.3,
  "dur": 5.56,
  "nchars": 20,
  "text": "在淫爱前受贪资具淫爱为得诸境界遍驰求名取",
  "flag": ""
 },
 {
  "id": "世间-24",
  "pin": "世间品",
  "localNo": 24,
  "globalNo": 145,
  "start": 129.3,
  "end": 134.8,
  "dur": 5.5,
  "nchars": 20,
  "text": "有谓正能造牵当有果业结当有名生至当受老死",
  "flag": ""
 },
 {
  "id": "世间-25",
  "pin": "世间品",
  "localNo": 25,
  "globalNo": 146,
  "start": 134.8,
  "end": 140.38,
  "dur": 5.58,
  "nchars": 20,
  "text": "传许约位说从胜立支名于前后中际为遣他愚惑",
  "flag": ""
 },
 {
  "id": "世间-26",
  "pin": "世间品",
  "localNo": 26,
  "globalNo": 147,
  "start": 140.4,
  "end": 145.94,
  "dur": 5.54,
  "nchars": 20,
  "text": "三烦恼二业七事亦名果略果及略因由中可比二",
  "flag": ""
 },
 {
  "id": "世间-27",
  "pin": "世间品",
  "localNo": 27,
  "globalNo": 148,
  "start": 145.94,
  "end": 151.37,
  "dur": 5.43,
  "nchars": 20,
  "text": "从惑生惑业从业生于事从事事惑生有支理唯此",
  "flag": ""
 },
 {
  "id": "世间-28",
  "pin": "世间品",
  "localNo": 28,
  "globalNo": 149,
  "start": 151.61,
  "end": 156.94,
  "dur": 5.33,
  "nchars": 20,
  "text": "此中意正说因起果已生明所治无明如非亲实等",
  "flag": ""
 },
 {
  "id": "世间-29",
  "pin": "世间品",
  "localNo": 29,
  "globalNo": 150,
  "start": 156.94,
  "end": 162.44,
  "dur": 5.5,
  "nchars": 20,
  "text": "说为结等故非恶慧见故与见相应故说能染慧故",
  "flag": ""
 },
 {
  "id": "世间-30",
  "pin": "世间品",
  "localNo": 30,
  "globalNo": 151,
  "start": 162.65,
  "end": 167.92,
  "dur": 5.27,
  "nchars": 20,
  "text": "名无色四蕴触六三和生五相应有对第六俱增语",
  "flag": ""
 },
 {
  "id": "世间-31",
  "pin": "世间品",
  "localNo": 31,
  "globalNo": 152,
  "start": 168.11,
  "end": 173.76,
  "dur": 5.65,
  "nchars": 20,
  "text": "明无明非二无漏染污余爱恚二相应乐等顺三受",
  "flag": ""
 },
 {
  "id": "世间-32",
  "pin": "世间品",
  "localNo": 32,
  "globalNo": 153,
  "start": 173.76,
  "end": 179.4,
  "dur": 5.64,
  "nchars": 20,
  "text": "从此生六受五属身余心此复成十八由意近行异",
  "flag": ""
 },
 {
  "id": "世间-33",
  "pin": "世间品",
  "localNo": 33,
  "globalNo": 154,
  "start": 179.4,
  "end": 185.0,
  "dur": 5.6,
  "nchars": 20,
  "text": "欲缘欲十八色十二上三二缘欲十二八自二无色",
  "flag": ""
 },
 {
  "id": "世间-34",
  "pin": "世间品",
  "localNo": 34,
  "globalNo": 155,
  "start": 185.0,
  "end": 190.56,
  "dur": 5.56,
  "nchars": 20,
  "text": "后二缘欲六四自一上缘初无色近分缘色四自一",
  "flag": ""
 },
 {
  "id": "世间-35",
  "pin": "世间品",
  "localNo": 35,
  "globalNo": 156,
  "start": 190.56,
  "end": 195.98,
  "dur": 5.42,
  "nchars": 20,
  "text": "四本及三边唯一缘自境十八唯有漏余已说当说",
  "flag": ""
 },
 {
  "id": "世间-36",
  "pin": "世间品",
  "localNo": 36,
  "globalNo": 157,
  "start": 195.98,
  "end": 201.3,
  "dur": 5.32,
  "nchars": 20,
  "text": "此中说烦恼如种复如龙如草根树茎及如糠裹米",
  "flag": ""
 },
 {
  "id": "世间-37",
  "pin": "世间品",
  "localNo": 37,
  "globalNo": 158,
  "start": 201.42,
  "end": 206.92,
  "dur": 5.5,
  "nchars": 20,
  "text": "业如有糠米如草药如花诸异熟果事如成熟饮食",
  "flag": ""
 },
 {
  "id": "世间-38",
  "pin": "世间品",
  "localNo": 38,
  "globalNo": 159,
  "start": 206.92,
  "end": 212.46,
  "dur": 5.54,
  "nchars": 20,
  "text": "于四种有中生有唯染污由自地烦恼余三无色三",
  "flag": ""
 },
 {
  "id": "世间-39",
  "pin": "世间品",
  "localNo": 39,
  "globalNo": 160,
  "start": 212.46,
  "end": 218.08,
  "dur": 5.62,
  "nchars": 20,
  "text": "有情由食住段欲体唯三非色不能益自根解脱故",
  "flag": ""
 },
 {
  "id": "世间-40",
  "pin": "世间品",
  "localNo": 40,
  "globalNo": 161,
  "start": 218.08,
  "end": 223.42,
  "dur": 5.34,
  "nchars": 20,
  "text": "触思识三食有漏通三界意成及求生食香中有起",
  "flag": ""
 },
 {
  "id": "世间-41",
  "pin": "世间品",
  "localNo": 41,
  "globalNo": 162,
  "start": 223.54,
  "end": 228.85,
  "dur": 5.31,
  "nchars": 20,
  "text": "前二益此世所依及能依后二于当有引及起如次",
  "flag": ""
 },
 {
  "id": "世间-42",
  "pin": "世间品",
  "localNo": 42,
  "globalNo": 163,
  "start": 229.0,
  "end": 234.56,
  "dur": 5.56,
  "nchars": 20,
  "text": "断善根与续离染退死生许唯意识中死生唯舍受",
  "flag": ""
 },
 {
  "id": "世间-43",
  "pin": "世间品",
  "localNo": 43,
  "globalNo": 164,
  "start": 234.56,
  "end": 240.08,
  "dur": 5.52,
  "nchars": 20,
  "text": "非定无心二二无记涅槃渐死足脐心最后意识灭",
  "flag": ""
 },
 {
  "id": "世间-44",
  "pin": "世间品",
  "localNo": 44,
  "globalNo": 165,
  "start": 240.08,
  "end": 245.54,
  "dur": 5.46,
  "nchars": 20,
  "text": "下人天不生断末摩水等正邪不定聚圣造无间余",
  "flag": ""
 },
 {
  "id": "世间-45",
  "pin": "世间品",
  "localNo": 45,
  "globalNo": 166,
  "start": 245.54,
  "end": 251.04,
  "dur": 5.5,
  "nchars": 20,
  "text": "安立器世间风轮最居下其量广无数厚十六洛叉",
  "flag": ""
 },
 {
  "id": "世间-46",
  "pin": "世间品",
  "localNo": 46,
  "globalNo": 167,
  "start": 251.04,
  "end": 256.68,
  "dur": 5.64,
  "nchars": 20,
  "text": "次上水轮深十一亿二万下八洛叉水余凝结成金",
  "flag": ""
 },
 {
  "id": "世间-47",
  "pin": "世间品",
  "localNo": 47,
  "globalNo": 168,
  "start": 256.68,
  "end": 262.22,
  "dur": 5.54,
  "nchars": 20,
  "text": "此水金轮广径十二洛叉三千四百半周围此三倍",
  "flag": ""
 },
 {
  "id": "世间-48",
  "pin": "世间品",
  "localNo": 48,
  "globalNo": 169,
  "start": 262.22,
  "end": 267.76,
  "dur": 5.54,
  "nchars": 20,
  "text": "苏迷卢处中次踰健达罗伊沙驮罗山竭地洛迦山",
  "flag": ""
 },
 {
  "id": "世间-49",
  "pin": "世间品",
  "localNo": 49,
  "globalNo": 170,
  "start": 267.76,
  "end": 273.28,
  "dur": 5.52,
  "nchars": 20,
  "text": "苏达黎舍那頞湿缚羯拏毗那怛迦山尼民达罗山",
  "flag": ""
 },
 {
  "id": "世间-50",
  "pin": "世间品",
  "localNo": 50,
  "globalNo": 171,
  "start": 273.28,
  "end": 278.72,
  "dur": 5.44,
  "nchars": 20,
  "text": "于大洲等外有铁轮围山前七金所成苏迷卢四宝",
  "flag": ""
 },
 {
  "id": "世间-51",
  "pin": "世间品",
  "localNo": 51,
  "globalNo": 172,
  "start": 278.72,
  "end": 284.18,
  "dur": 5.46,
  "nchars": 20,
  "text": "入水皆八万妙高出亦然余八半半下广皆等高量",
  "flag": ""
 },
 {
  "id": "世间-52",
  "pin": "世间品",
  "localNo": 52,
  "globalNo": 173,
  "start": 284.18,
  "end": 289.52,
  "dur": 5.34,
  "nchars": 20,
  "text": "山间有八海前七名为内最初广八万四边各三倍",
  "flag": ""
 },
 {
  "id": "世间-53",
  "pin": "世间品",
  "localNo": 53,
  "globalNo": 174,
  "start": 289.52,
  "end": 295.18,
  "dur": 5.66,
  "nchars": 20,
  "text": "余六半半狭第八名为外三洛叉二万二千踰缮那",
  "flag": ""
 },
 {
  "id": "世间-54",
  "pin": "世间品",
  "localNo": 54,
  "globalNo": 175,
  "start": 295.18,
  "end": 300.62,
  "dur": 5.44,
  "nchars": 20,
  "text": "于中大洲相南赡部如车三边各二千南边有三半",
  "flag": ""
 },
 {
  "id": "世间-55",
  "pin": "世间品",
  "localNo": 55,
  "globalNo": 176,
  "start": 300.62,
  "end": 306.06,
  "dur": 5.44,
  "nchars": 20,
  "text": "东毗提诃洲其相如半月三边如赡部东边三百半",
  "flag": ""
 },
 {
  "id": "世间-56",
  "pin": "世间品",
  "localNo": 56,
  "globalNo": 177,
  "start": 306.06,
  "end": 311.46,
  "dur": 5.4,
  "nchars": 20,
  "text": "西瞿陀尼洲其相圆无缺径二千五百周围此三倍",
  "flag": ""
 },
 {
  "id": "世间-57",
  "pin": "世间品",
  "localNo": 57,
  "globalNo": 178,
  "start": 311.46,
  "end": 316.92,
  "dur": 5.46,
  "nchars": 20,
  "text": "北俱卢畟方面各二千等中洲复有八四洲边各二",
  "flag": ""
 },
 {
  "id": "世间-58",
  "pin": "世间品",
  "localNo": 58,
  "globalNo": 179,
  "start": 317.15,
  "end": 322.34,
  "dur": 5.19,
  "nchars": 20,
  "text": "此北九黑山雪香醉山内无热池纵广五十踰缮那",
  "flag": ""
 },
 {
  "id": "世间-59",
  "pin": "世间品",
  "localNo": 59,
  "globalNo": 180,
  "start": 322.34,
  "end": 327.76,
  "dur": 5.42,
  "nchars": 20,
  "text": "此下过二万无间深广同上七捺落迦八增皆十六",
  "flag": ""
 },
 {
  "id": "世间-60",
  "pin": "世间品",
  "localNo": 60,
  "globalNo": 181,
  "start": 327.76,
  "end": 333.3,
  "dur": 5.54,
  "nchars": 20,
  "text": "谓煻煨尸粪锋刃烈河增各住彼四方余八寒地狱",
  "flag": ""
 },
 {
  "id": "世间-61",
  "pin": "世间品",
  "localNo": 61,
  "globalNo": 182,
  "start": 333.3,
  "end": 338.8,
  "dur": 5.5,
  "nchars": 20,
  "text": "日月迷卢半五十一五十夜半日没中日出四洲等",
  "flag": ""
 },
 {
  "id": "世间-62",
  "pin": "世间品",
  "localNo": 62,
  "globalNo": 183,
  "start": 338.8,
  "end": 344.06,
  "dur": 5.26,
  "nchars": 20,
