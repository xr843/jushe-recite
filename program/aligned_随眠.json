[
 {
  "id": "随眠-1",
  "pin": "随眠品",
  "localNo": 1,
  "globalNo": 352,
  "start": 0.0,
  "end": 5.84,
  "dur": 5.84,
  "nchars": 20,
  "text": "随眠诸有本此差别有六谓贪瞋亦慢无明见及疑",
  "flag": ""
 },
 {
  "id": "随眠-2",
  "pin": "随眠品",
  "localNo": 2,
  "globalNo": 353,
  "start": 5.84,
  "end": 11.62,
  "dur": 5.78,
  "nchars": 20,
  "text": "六由贪异七有贪上二界于内门转故为遮解脱想",
  "flag": ""
 },
 {
  "id": "随眠-3",
  "pin": "随眠品",
  "localNo": 3,
  "globalNo": 354,
  "start": 11.62,
  "end": 17.56,
  "dur": 5.94,
  "nchars": 20,
  "text": "六由见异十异谓有身见边执见邪见见取戒禁取",
  "flag": ""
 },
 {
  "id": "随眠-4",
  "pin": "随眠品",
  "localNo": 4,
  "globalNo": 355,
  "start": 17.56,
  "end": 23.34,
  "dur": 5.78,
  "nchars": 20,
  "text": "六行部界异故成九十八欲见苦等断十七七八四",
  "flag": ""
 },
 {
  "id": "随眠-5",
  "pin": "随眠品",
  "localNo": 5,
  "globalNo": 356,
  "start": 23.34,
  "end": 29.12,
  "dur": 5.78,
  "nchars": 20,
  "text": "谓如次具离三二见见疑色无色除瞋余等如欲说",
  "flag": ""
 },
 {
  "id": "随眠-6",
  "pin": "随眠品",
  "localNo": 6,
  "globalNo": 357,
  "start": 29.12,
  "end": 35.12,
  "dur": 6.0,
  "nchars": 20,
  "text": "忍所害随眠有顶唯见断余通见修断智所害唯修",
  "flag": ""
 },
 {
  "id": "随眠-7",
  "pin": "随眠品",
  "localNo": 7,
  "globalNo": 358,
  "start": 35.12,
  "end": 40.63,
  "dur": 5.51,
  "nchars": 20,
  "text": "我我所断常拨无劣谓胜非因道妄谓是五见自体",
  "flag": ""
 },
 {
  "id": "随眠-8",
  "pin": "随眠品",
  "localNo": 8,
  "globalNo": 359,
  "start": 40.72,
  "end": 46.8,
  "dur": 6.08,
  "nchars": 20,
  "text": "于大自在等非因妄执因从常我倒生故唯见苦断",
  "flag": ""
 },
 {
  "id": "随眠-9",
  "pin": "随眠品",
  "localNo": 9,
  "globalNo": 360,
  "start": 46.8,
  "end": 52.58,
  "dur": 5.78,
  "nchars": 20,
  "text": "四颠倒自体谓从于三见唯倒推增故想心随见力",
  "flag": ""
 },
 {
  "id": "随眠-10",
  "pin": "随眠品",
  "localNo": 10,
  "globalNo": 361,
  "start": 52.58,
  "end": 58.44,
  "dur": 5.86,
  "nchars": 20,
  "text": "慢七九从三皆通见修断圣如杀缠等有修断不行",
  "flag": ""
 },
 {
  "id": "随眠-11",
  "pin": "随眠品",
  "localNo": 11,
  "globalNo": 362,
  "start": 58.44,
  "end": 64.26,
  "dur": 5.82,
  "nchars": 20,
  "text": "慢类等我慢恶作中不善圣有而不起见疑所增故",
  "flag": ""
 },
 {
  "id": "随眠-12",
  "pin": "随眠品",
  "localNo": 12,
  "globalNo": 363,
  "start": 64.26,
  "end": 70.06,
  "dur": 5.8,
  "nchars": 20,
  "text": "见苦集所断诸见疑相应及不共无明遍行自界地",
  "flag": ""
 },
 {
  "id": "随眠-13",
  "pin": "随眠品",
  "localNo": 13,
  "globalNo": 364,
  "start": 70.06,
  "end": 75.92,
  "dur": 5.86,
  "nchars": 20,
  "text": "于中除二见余九能上缘除得余随行亦是遍行摄",
  "flag": ""
 },
 {
  "id": "随眠-14",
  "pin": "随眠品",
  "localNo": 14,
  "globalNo": 365,
  "start": 75.92,
  "end": 81.74,
  "dur": 5.82,
  "nchars": 20,
  "text": "见灭道所断邪见疑相应及不共无明六能缘无漏",
  "flag": ""
 },
 {
  "id": "随眠-15",
  "pin": "随眠品",
  "localNo": 15,
  "globalNo": 366,
  "start": 81.74,
  "end": 87.54,
  "dur": 5.8,
  "nchars": 20,
  "text": "于中缘灭者唯缘自地灭缘道六九地由别治相因",
  "flag": ""
 },
 {
  "id": "随眠-16",
  "pin": "随眠品",
  "localNo": 16,
  "globalNo": 367,
  "start": 87.54,
  "end": 93.34,
  "dur": 5.8,
  "nchars": 20,
  "text": "贪瞋慢二取并非无漏缘应离境非怨静净胜性故",
  "flag": ""
 },
 {
  "id": "随眠-17",
  "pin": "随眠品",
  "localNo": 17,
  "globalNo": 368,
  "start": 93.34,
  "end": 99.24,
  "dur": 5.9,
  "nchars": 20,
  "text": "未断遍随眠于自地一切非遍于自部所缘故随增",
  "flag": ""
 },
 {
  "id": "随眠-18",
  "pin": "随眠品",
  "localNo": 18,
  "globalNo": 369,
  "start": 99.24,
  "end": 105.06,
  "dur": 5.82,
  "nchars": 20,
  "text": "非无漏上缘无摄有违故随于相应法相应故随增",
  "flag": ""
 },
 {
  "id": "随眠-19",
  "pin": "随眠品",
  "localNo": 19,
  "globalNo": 370,
  "start": 105.06,
  "end": 110.76,
  "dur": 5.7,
  "nchars": 20,
  "text": "上二界随眠及欲身边见彼俱痴无记此余皆不善",
  "flag": ""
 },
 {
  "id": "随眠-20",
  "pin": "随眠品",
  "localNo": 20,
  "globalNo": 371,
  "start": 110.76,
  "end": 116.52,
  "dur": 5.76,
  "nchars": 20,
  "text": "不善根欲界贪瞋不善痴无记根有三无记爱痴慧",
  "flag": ""
 },
 {
  "id": "随眠-21",
  "pin": "随眠品",
  "localNo": 21,
  "globalNo": 372,
  "start": 116.52,
  "end": 122.3,
  "dur": 5.78,
  "nchars": 20,
  "text": "非余二高故外方立四种中爱见慢痴三定皆痴故",
  "flag": ""
 },
 {
  "id": "随眠-22",
  "pin": "随眠品",
  "localNo": 22,
  "globalNo": 373,
  "start": 122.3,
  "end": 128.2,
  "dur": 5.9,
  "nchars": 20,
  "text": "应一向分别反诘舍置记如死生殊胜我蕴一异等",
  "flag": ""
 },
 {
  "id": "随眠-23",
  "pin": "随眠品",
  "localNo": 23,
  "globalNo": 374,
  "start": 128.2,
  "end": 134.0,
  "dur": 5.8,
  "nchars": 20,
  "text": "若于此事中未断贪瞋慢过现若已起未来意遍行",
  "flag": ""
 },
 {
  "id": "随眠-24",
  "pin": "随眠品",
  "localNo": 24,
  "globalNo": 375,
  "start": 134.0,
  "end": 139.7,
  "dur": 5.7,
  "nchars": 20,
  "text": "五可生自世不生亦遍行余过未遍行现正缘能系",
  "flag": ""
 },
 {
  "id": "随眠-25",
  "pin": "随眠品",
  "localNo": 25,
  "globalNo": 376,
  "start": 139.7,
  "end": 145.44,
  "dur": 5.74,
  "nchars": 20,
  "text": "三世有由说二有境果故说三世有故许说一切有",
  "flag": ""
 },
 {
  "id": "随眠-26",
  "pin": "随眠品",
  "localNo": 26,
  "globalNo": 377,
  "start": 145.44,
  "end": 151.18,
  "dur": 5.74,
  "nchars": 20,
  "text": "此中有四种类相位待异第三约作用立世最为善",
  "flag": ""
 },
 {
  "id": "随眠-27",
  "pin": "随眠品",
  "localNo": 27,
  "globalNo": 378,
  "start": 151.18,
  "end": 156.94,
  "dur": 5.76,
  "nchars": 20,
  "text": "何碍用云何无异世便坏有谁未生灭此法性甚深",
  "flag": ""
 },
 {
  "id": "随眠-28",
  "pin": "随眠品",
  "localNo": 28,
  "globalNo": 379,
  "start": 156.94,
  "end": 162.72,
  "dur": 5.78,
  "nchars": 20,
  "text": "于见苦已断余遍行随眠及前品已断余缘此犹系",
  "flag": ""
 },
 {
  "id": "随眠-29",
  "pin": "随眠品",
  "localNo": 29,
  "globalNo": 380,
  "start": 162.72,
  "end": 168.56,
  "dur": 5.84,
  "nchars": 20,
  "text": "见苦集修断若欲界所系自界三色一无漏识所行",
  "flag": ""
 },
 {
  "id": "随眠-30",
  "pin": "随眠品",
  "localNo": 30,
  "globalNo": 381,
  "start": 168.56,
  "end": 174.14,
  "dur": 5.58,
  "nchars": 20,
  "text": "色自下各三上一净识境无色通三界各三净识境",
  "flag": ""
 },
 {
  "id": "随眠-31",
  "pin": "随眠品",
  "localNo": 31,
  "globalNo": 382,
  "start": 174.34,
  "end": 180.0,
  "dur": 5.66,
  "nchars": 20,
  "text": "见灭道所断皆增自识行无漏三界中后三净识境",
  "flag": ""
 },
 {
  "id": "随眠-32",
  "pin": "随眠品",
  "localNo": 32,
  "globalNo": 383,
  "start": 180.0,
  "end": 185.68,
  "dur": 5.68,
  "nchars": 20,
  "text": "有随眠心二谓有染无染有染心通二无染局随增",
  "flag": ""
 },
 {
  "id": "随眠-33",
  "pin": "随眠品",
  "localNo": 33,
  "globalNo": 384,
  "start": 185.68,
  "end": 191.3,
  "dur": 5.62,
  "nchars": 20,
  "text": "无明疑邪身边见戒见取贪慢瞋如次由前引后生",
  "flag": ""
 },
 {
  "id": "随眠-34",
  "pin": "随眠品",
  "localNo": 34,
  "globalNo": 385,
  "start": 191.3,
  "end": 197.08,
  "dur": 5.78,
  "nchars": 20,
  "text": "由未断随眠及随应境现非理作意起说惑具因缘",
  "flag": ""
 },
 {
  "id": "随眠-35",
  "pin": "随眠品",
  "localNo": 35,
  "globalNo": 386,
  "start": 197.08,
  "end": 202.72,
  "dur": 5.64,
  "nchars": 20,
  "text": "欲烦恼并缠除痴名欲漏有漏上二界唯烦恼除痴",
  "flag": ""
 },
 {
  "id": "随眠-36",
  "pin": "随眠品",
  "localNo": 36,
  "globalNo": 387,
  "start": 202.72,
  "end": 208.48,
  "dur": 5.76,
  "nchars": 20,
  "text": "同无记内门定地故合一无明诸有本故别为一漏",
  "flag": ""
 },
 {
  "id": "随眠-37",
  "pin": "随眠品",
  "localNo": 37,
  "globalNo": 388,
  "start": 208.68,
  "end": 214.14,
  "dur": 5.46,
  "nchars": 20,
  "text": "瀑流轭亦然别立见利故见不顺住故非于漏独立",
  "flag": ""
 },
 {
  "id": "随眠-38",
  "pin": "随眠品",
  "localNo": 38,
  "globalNo": 389,
  "start": 214.14,
  "end": 219.8,
  "dur": 5.66,
  "nchars": 20,
  "text": "欲有轭并痴见分二名取无明不别立以非能取故",
  "flag": ""
 },
 {
  "id": "随眠-39",
  "pin": "随眠品",
  "localNo": 39,
  "globalNo": 390,
  "start": 220.03,
  "end": 225.46,
  "dur": 5.43,
  "nchars": 20,
  "text": "微细二随增随逐与随缚住流漂合执是随眠等义",
  "flag": ""
 },
 {
  "id": "随眠-40",
  "pin": "随眠品",
  "localNo": 40,
  "globalNo": 391,
  "start": 225.46,
  "end": 231.04,
  "dur": 5.58,
  "nchars": 20,
  "text": "由结等差别复说有五种结九物取等立见取二结",
  "flag": ""
 },
 {
  "id": "随眠-41",
  "pin": "随眠品",
  "localNo": 41,
  "globalNo": 392,
  "start": 231.04,
  "end": 236.58,
  "dur": 5.54,
  "nchars": 20,
  "text": "由二唯不善及自在起故缠中唯嫉悭建立为二结",
  "flag": ""
 },
 {
  "id": "随眠-42",
  "pin": "随眠品",
  "localNo": 42,
  "globalNo": 393,
  "start": 236.58,
  "end": 242.24,
  "dur": 5.66,
  "nchars": 20,
  "text": "或二数行故为贱贫因故遍显随惑故恼乱二部故",
  "flag": ""
 },
 {
  "id": "随眠-43",
  "pin": "随眠品",
  "localNo": 43,
  "globalNo": 394,
  "start": 242.24,
  "end": 247.92,
  "dur": 5.68,
  "nchars": 20,
  "text": "又五顺下分由二不超欲由三复还下摄门根故三",
  "flag": ""
 },
 {
  "id": "随眠-44",
  "pin": "随眠品",
  "localNo": 44,
  "globalNo": 395,
  "start": 247.92,
  "end": 253.56,
  "dur": 5.64,
  "nchars": 20,
  "text": "或不欲发趣迷道及疑道能障趣解脱故唯说断三",
  "flag": ""
 },
 {
  "id": "随眠-45",
  "pin": "随眠品",
  "localNo": 45,
  "globalNo": 396,
  "start": 253.79,
  "end": 259.18,
  "dur": 5.39,
  "nchars": 20,
  "text": "顺上分亦五色无色二贪掉举慢无明令不超上故",
  "flag": ""
 },
 {
  "id": "随眠-46",
  "pin": "随眠品",
  "localNo": 46,
  "globalNo": 397,
  "start": 259.18,
  "end": 264.96,
  "dur": 5.78,
  "nchars": 20,
  "text": "缚三由三受随眠前已说随烦恼此余染心所行蕴",
  "flag": ""
 },
 {
  "id": "随眠-47",
  "pin": "随眠品",
  "localNo": 47,
  "globalNo": 398,
  "start": 264.96,
  "end": 270.54,
  "dur": 5.58,
  "nchars": 20,
  "text": "缠八无惭愧嫉悭并悔眠及掉举昏沉或十加忿覆",
  "flag": ""
 },
 {
  "id": "随眠-48",
  "pin": "随眠品",
  "localNo": 48,
  "globalNo": 399,
  "start": 270.54,
  "end": 276.28,
  "dur": 5.74,
  "nchars": 20,
  "text": "无惭悭掉举皆从贪所生无愧眠昏沉从无明所起",
  "flag": ""
 },
 {
  "id": "随眠-49",
  "pin": "随眠品",
  "localNo": 49,
  "globalNo": 400,
  "start": 276.28,
  "end": 281.96,
  "dur": 5.68,
  "nchars": 20,
  "text": "嫉忿从瞋起悔从疑覆诤烦恼垢六恼害恨谄诳骄",
  "flag": ""
 },
 {
  "id": "随眠-50",
  "pin": "随眠品",
  "localNo": 50,
  "globalNo": 401,
  "start": 282.17,
  "end": 287.58,
  "dur": 5.41,
  "nchars": 20,
  "text": "诳骄从贪生害恨从瞋起恼从见取起谄从诸见生",
  "flag": ""
 },
 {
  "id": "随眠-51",
  "pin": "随眠品",
  "localNo": 51,
  "globalNo": 402,
  "start": 287.58,
  "end": 293.26,
  "dur": 5.68,
  "nchars": 20,
  "text": "缠无惭愧眠昏掉见修断余及烦恼垢自在故唯修",
  "flag": ""
 },
 {
  "id": "随眠-52",
  "pin": "随眠品",
  "localNo": 52,
  "globalNo": 403,
  "start": 293.26,
  "end": 298.96,
  "dur": 5.7,
  "nchars": 20,
  "text": "欲三二余恶上界皆无记谄诳欲初定三三界余欲",
  "flag": ""
 },
 {
  "id": "随眠-53",
  "pin": "随眠品",
  "localNo": 53,
  "globalNo": 404,
  "start": 298.96,
  "end": 304.44,
  "dur": 5.48,
  "nchars": 20,
  "text": "见所断慢眠自在随烦恼皆唯意地起余通依六识",
  "flag": ""
 },
 {
  "id": "随眠-54",
  "pin": "随眠品",
  "localNo": 54,
  "globalNo": 405,
  "start": 304.44,
  "end": 309.98,
  "dur": 5.54,
  "nchars": 20,
  "text": "欲界诸烦恼贪喜乐相应瞋忧苦痴遍邪见忧及喜",
  "flag": ""
 },
 {
  "id": "随眠-55",
  "pin": "随眠品",
  "localNo": 55,
  "globalNo": 406,
  "start": 309.98,
  "end": 315.66,
  "dur": 5.68,
  "nchars": 20,
  "text": "疑忧余五喜一切舍相应上地皆随应遍自识诸受",
  "flag": ""
 },
 {
  "id": "随眠-56",
  "pin": "随眠品",
  "localNo": 56,
  "globalNo": 407,
  "start": 315.66,
  "end": 321.2,
  "dur": 5.54,
  "nchars": 20,
  "text": "诸随烦恼中嫉悔忿及恼害恨忧俱起悭喜受相应",
  "flag": ""
 },
 {
  "id": "随眠-57",
  "pin": "随眠品",
  "localNo": 57,
  "globalNo": 408,
  "start": 321.43,
  "end": 326.88,
  "dur": 5.45,
  "nchars": 20,
  "text": "谄诳及眠覆通忧喜俱起骄喜乐皆舍余四遍相应",
  "flag": ""
 },
 {
  "id": "随眠-58",
  "pin": "随眠品",
  "localNo": 58,
  "globalNo": 409,
  "start": 326.88,
  "end": 332.42,
  "dur": 5.54,
  "nchars": 20,
  "text": "盖五唯在欲食治用同故虽二立一盖障蕴故唯五",
  "flag": ""
 },
 {
  "id": "随眠-59",
  "pin": "随眠品",
  "localNo": 59,
  "globalNo": 410,
  "start": 332.42,
  "end": 338.02,
  "dur": 5.6,
  "nchars": 20,
  "text": "遍知所缘故断彼能缘故断彼所缘故对治起故断",
  "flag": ""
 },
 {
  "id": "随眠-60",
  "pin": "随眠品",
  "localNo": 60,
  "globalNo": 411,
  "start": 338.02,
  "end": 343.68,
