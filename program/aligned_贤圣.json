[
 {
  "id": "贤圣-1",
  "pin": "贤圣品",
  "localNo": 1,
  "globalNo": 421,
  "start": 0.0,
  "end": 5.5,
  "dur": 5.5,
  "nchars": 20,
  "text": "已说烦恼断由见谛修故见道唯无漏修道通二种",
  "flag": ""
 },
 {
  "id": "贤圣-2",
  "pin": "贤圣品",
  "localNo": 2,
  "globalNo": 422,
  "start": 5.5,
  "end": 11.16,
  "dur": 5.66,
  "nchars": 20,
  "text": "谛四名已说谓苦集灭道彼自体亦然次第随现观",
  "flag": ""
 },
 {
  "id": "贤圣-3",
  "pin": "贤圣品",
  "localNo": 3,
  "globalNo": 423,
  "start": 11.16,
  "end": 16.74,
  "dur": 5.58,
  "nchars": 20,
  "text": "苦由三苦合如所应一切可意非可意余有漏行法",
  "flag": ""
 },
 {
  "id": "贤圣-4",
  "pin": "贤圣品",
  "localNo": 4,
  "globalNo": 424,
  "start": 16.74,
  "end": 22.46,
  "dur": 5.72,
  "nchars": 20,
  "text": "彼觉破便无慧析余亦尔如瓶水世俗异此名胜义",
  "flag": ""
 },
 {
  "id": "贤圣-5",
  "pin": "贤圣品",
  "localNo": 5,
  "globalNo": 425,
  "start": 22.46,
  "end": 27.98,
  "dur": 5.52,
  "nchars": 20,
  "text": "将趣见谛道应住戒勤修闻思修所成谓名俱义境",
  "flag": ""
 },
 {
  "id": "贤圣-6",
  "pin": "贤圣品",
  "localNo": 6,
  "globalNo": 426,
  "start": 28.12,
  "end": 33.74,
  "dur": 5.62,
  "nchars": 20,
  "text": "具身心远离无不足大欲谓已得未得多求名所无",
  "flag": ""
 },
 {
  "id": "贤圣-7",
  "pin": "贤圣品",
  "localNo": 7,
  "globalNo": 427,
  "start": 33.74,
  "end": 39.34,
  "dur": 5.6,
  "nchars": 20,
  "text": "治相违界三无漏无贪性四圣种亦尔前三唯喜足",
  "flag": ""
 },
 {
  "id": "贤圣-8",
  "pin": "贤圣品",
  "localNo": 8,
  "globalNo": 428,
  "start": 39.34,
  "end": 45.06,
  "dur": 5.72,
  "nchars": 20,
  "text": "三生具后业为治四爱生我所我事欲暂息永除故",
  "flag": ""
 },
 {
  "id": "贤圣-9",
  "pin": "贤圣品",
  "localNo": 9,
  "globalNo": 429,
  "start": 45.06,
  "end": 50.78,
  "dur": 5.72,
  "nchars": 20,
  "text": "入修要二门不净观息念贪寻增上者如次第应修",
  "flag": ""
 },
 {
  "id": "贤圣-10",
  "pin": "贤圣品",
  "localNo": 10,
  "globalNo": 430,
  "start": 50.78,
  "end": 56.34,
  "dur": 5.56,
  "nchars": 20,
  "text": "为通治四贪且辨观骨锁广至海复略名初习业位",
  "flag": ""
 },
 {
  "id": "贤圣-11",
  "pin": "贤圣品",
  "localNo": 11,
  "globalNo": 431,
  "start": 56.34,
  "end": 61.94,
  "dur": 5.6,
  "nchars": 20,
  "text": "除足至头半名为已熟修系心在眉间名超作意位",
  "flag": ""
 },
 {
  "id": "贤圣-12",
  "pin": "贤圣品",
  "localNo": 12,
  "globalNo": 432,
  "start": 61.94,
  "end": 67.62,
  "dur": 5.68,
  "nchars": 20,
  "text": "无贪性十地缘欲色人生不净自世缘有漏通二得",
  "flag": ""
 },
 {
  "id": "贤圣-13",
  "pin": "贤圣品",
  "localNo": 13,
  "globalNo": 433,
  "start": 67.86,
  "end": 73.24,
  "dur": 5.38,
  "nchars": 20,
  "text": "息念慧五地缘风依欲身二得实外无有六谓数等",
  "flag": ""
 },
 {
  "id": "贤圣-14",
  "pin": "贤圣品",
  "localNo": 14,
  "globalNo": 434,
  "start": 73.24,
  "end": 78.92,
  "dur": 5.68,
  "nchars": 20,
  "text": "入出息随身依二差别转情数非执受等流非下缘",
  "flag": ""
 },
 {
  "id": "贤圣-15",
  "pin": "贤圣品",
  "localNo": 15,
  "globalNo": 435,
  "start": 78.92,
  "end": 84.4,
  "dur": 5.48,
  "nchars": 20,
  "text": "依已修成止为观修念住以自相共相观身受心法",
  "flag": ""
 },
 {
  "id": "贤圣-16",
  "pin": "贤圣品",
  "localNo": 16,
  "globalNo": 436,
  "start": 84.4,
  "end": 90.06,
  "dur": 5.66,
  "nchars": 20,
  "text": "自性闻等慧余相杂所缘说次第随生治倒故唯四",
  "flag": ""
 },
 {
  "id": "贤圣-17",
  "pin": "贤圣品",
  "localNo": 17,
  "globalNo": 437,
  "start": 90.06,
  "end": 95.68,
  "dur": 5.62,
  "nchars": 20,
  "text": "彼居法念住总观四所缘修非常及苦空非我行相",
  "flag": ""
 },
 {
  "id": "贤圣-18",
  "pin": "贤圣品",
  "localNo": 18,
  "globalNo": 438,
  "start": 95.68,
  "end": 101.28,
  "dur": 5.6,
  "nchars": 20,
  "text": "从此生煖法具观四圣谛修十六行相次生顶亦然",
  "flag": ""
 },
 {
  "id": "贤圣-19",
  "pin": "贤圣品",
  "localNo": 19,
  "globalNo": 439,
  "start": 101.28,
  "end": 106.88,
  "dur": 5.6,
  "nchars": 20,
  "text": "如是二善根皆初法后四次忍唯法念下中品同顶",
  "flag": ""
 },
 {
  "id": "贤圣-20",
  "pin": "贤圣品",
  "localNo": 20,
  "globalNo": 440,
  "start": 106.88,
  "end": 112.5,
  "dur": 5.62,
  "nchars": 20,
  "text": "上唯观欲苦一行一剎那世第一亦然皆慧五除得",
  "flag": ""
 },
 {
  "id": "贤圣-21",
  "pin": "贤圣品",
  "localNo": 21,
  "globalNo": 441,
  "start": 112.5,
  "end": 118.06,
  "dur": 5.56,
  "nchars": 20,
  "text": "此顺决择分四皆修所成六地二或七依欲界身九",
  "flag": ""
 },
 {
  "id": "贤圣-22",
  "pin": "贤圣品",
  "localNo": 22,
  "globalNo": 442,
  "start": 118.06,
  "end": 123.6,
  "dur": 5.54,
  "nchars": 20,
  "text": "三女男得二第四女亦尔圣由失地舍异生由命终",
  "flag": ""
 },
 {
  "id": "贤圣-23",
  "pin": "贤圣品",
  "localNo": 23,
  "globalNo": 443,
  "start": 123.6,
  "end": 129.2,
  "dur": 5.6,
  "nchars": 20,
  "text": "初二亦退舍依本必见谛舍已得非先二舍性非得",
  "flag": ""
 },
 {
  "id": "贤圣-24",
  "pin": "贤圣品",
  "localNo": 24,
  "globalNo": 444,
  "start": 129.2,
  "end": 134.76,
  "dur": 5.56,
  "nchars": 20,
  "text": "煖必至涅槃顶终不断善忍不堕恶趣第一入离生",
  "flag": ""
 },
 {
  "id": "贤圣-25",
  "pin": "贤圣品",
  "localNo": 25,
  "globalNo": 445,
  "start": 134.76,
  "end": 140.32,
  "dur": 5.56,
  "nchars": 20,
  "text": "转声闻种姓二成佛三余麟角佛无转一座成觉故",
  "flag": ""
 },
 {
  "id": "贤圣-26",
  "pin": "贤圣品",
  "localNo": 26,
  "globalNo": 446,
  "start": 140.32,
  "end": 145.98,
  "dur": 5.66,
  "nchars": 20,
  "text": "前顺解脱分速三生解脱闻思成三业殖在人三洲",
  "flag": ""
 },
 {
  "id": "贤圣-27",
  "pin": "贤圣品",
  "localNo": 27,
  "globalNo": 447,
  "start": 145.98,
  "end": 151.62,
  "dur": 5.64,
  "nchars": 20,
  "text": "世第一无间即缘欲界苦生无漏法忍忍次生法智",
  "flag": ""
 },
 {
  "id": "贤圣-28",
  "pin": "贤圣品",
  "localNo": 28,
  "globalNo": 448,
  "start": 151.62,
  "end": 157.16,
  "dur": 5.54,
  "nchars": 20,
  "text": "次缘余界苦生类忍类智缘集灭道谛各生四亦然",
  "flag": ""
 },
 {
  "id": "贤圣-29",
  "pin": "贤圣品",
  "localNo": 29,
  "globalNo": 449,
  "start": 157.16,
  "end": 162.6,
  "dur": 5.44,
  "nchars": 20,
  "text": "如是十六心名圣谛现观此总有三种谓见缘事别",
  "flag": ""
 },
 {
  "id": "贤圣-30",
  "pin": "贤圣品",
  "localNo": 30,
  "globalNo": 450,
  "start": 162.6,
  "end": 168.16,
  "dur": 5.56,
  "nchars": 20,
  "text": "皆与世第一同依于一地忍智如次第无间解脱道",
  "flag": ""
 },
 {
  "id": "贤圣-31",
  "pin": "贤圣品",
  "localNo": 31,
  "globalNo": 451,
  "start": 168.16,
  "end": 173.6,
  "dur": 5.44,
  "nchars": 20,
  "text": "前十五见道见未曾见故名随信法行由根钝利别",
  "flag": ""
 },
 {
  "id": "贤圣-32",
  "pin": "贤圣品",
  "localNo": 32,
  "globalNo": 452,
  "start": 173.6,
  "end": 179.16,
  "dur": 5.56,
  "nchars": 20,
  "text": "具修惑断一至五向初果断次三向二离八地向三",
  "flag": ""
 },
 {
  "id": "贤圣-33",
  "pin": "贤圣品",
  "localNo": 33,
  "globalNo": 453,
  "start": 179.16,
  "end": 184.66,
  "dur": 5.5,
  "nchars": 20,
  "text": "至第十六心随三向住果名信解见至亦由钝利别",
  "flag": ""
 },
 {
  "id": "贤圣-34",
  "pin": "贤圣品",
  "localNo": 34,
  "globalNo": 454,
  "start": 184.66,
  "end": 190.08,
  "dur": 5.42,
  "nchars": 20,
  "text": "诸得果位中未得胜果道故未起胜道名住果非向",
  "flag": ""
 },
 {
  "id": "贤圣-35",
  "pin": "贤圣品",
  "localNo": 35,
  "globalNo": 455,
  "start": 190.08,
  "end": 195.4,
  "dur": 5.32,
  "nchars": 20,
  "text": "地地失德九下中上各三未断修断失住果极七返",
  "flag": ""
 },
 {
  "id": "贤圣-36",
  "pin": "贤圣品",
  "localNo": 36,
  "globalNo": 456,
  "start": 195.5,
  "end": 200.92,
  "dur": 5.42,
  "nchars": 20,
  "text": "断欲三四品三二生家家断至五二向断六一来果",
  "flag": ""
 },
 {
  "id": "贤圣-37",
  "pin": "贤圣品",
  "localNo": 37,
  "globalNo": 457,
  "start": 200.92,
  "end": 206.34,
  "dur": 5.42,
  "nchars": 20,
  "text": "断七或八品一生名一间此即第三向断九不还果",
  "flag": ""
 },
 {
  "id": "贤圣-38",
  "pin": "贤圣品",
  "localNo": 38,
  "globalNo": 458,
  "start": 206.34,
  "end": 211.9,
  "dur": 5.56,
  "nchars": 20,
  "text": "此中生有行无行般涅槃上流若杂修能往色究竟",
  "flag": ""
 },
 {
  "id": "贤圣-39",
  "pin": "贤圣品",
  "localNo": 39,
  "globalNo": 459,
  "start": 211.9,
  "end": 217.28,
  "dur": 5.38,
  "nchars": 20,
  "text": "超半超遍没余能往有顶行无色有四住此般涅槃",
  "flag": ""
 },
 {
  "id": "贤圣-40",
  "pin": "贤圣品",
  "localNo": 40,
  "globalNo": 460,
  "start": 217.28,
  "end": 222.74,
  "dur": 5.46,
  "nchars": 20,
  "text": "行色界有九谓三各分三业惑根有殊故成三九别",
  "flag": ""
 },
 {
  "id": "贤圣-41",
  "pin": "贤圣品",
  "localNo": 41,
  "globalNo": 461,
  "start": 222.74,
  "end": 228.24,
  "dur": 5.5,
  "nchars": 20,
  "text": "立七善士趣由上流无别善恶行不行有往无还故",
  "flag": ""
 },
 {
  "id": "贤圣-42",
  "pin": "贤圣品",
  "localNo": 42,
  "globalNo": 462,
  "start": 228.5,
  "end": 233.78,
  "dur": 5.28,
  "nchars": 20,
  "text": "经欲界生圣不往余界生此及往上生无练根并退",
  "flag": ""
 },
 {
  "id": "贤圣-43",
  "pin": "贤圣品",
  "localNo": 43,
  "globalNo": 463,
  "start": 233.98,
  "end": 239.24,
  "dur": 5.26,
  "nchars": 20,
  "text": "先杂修第四成由一念杂为受生现乐及遮烦恼退",
  "flag": ""
 },
 {
  "id": "贤圣-44",
  "pin": "贤圣品",
  "localNo": 44,
  "globalNo": 464,
  "start": 239.24,
  "end": 244.66,
  "dur": 5.42,
  "nchars": 20,
  "text": "由杂修五品生有五净居得灭定不还转名为身证",
  "flag": ""
 },
 {
  "id": "贤圣-45",
  "pin": "贤圣品",
  "localNo": 45,
  "globalNo": 465,
  "start": 244.66,
  "end": 250.08,
  "dur": 5.42,
  "nchars": 20,
  "text": "上界修惑中断初定一品至有顶八品皆阿罗汉向",
  "flag": ""
 },
 {
  "id": "贤圣-46",
  "pin": "贤圣品",
  "localNo": 46,
  "globalNo": 466,
  "start": 250.08,
  "end": 255.48,
  "dur": 5.4,
  "nchars": 20,
  "text": "第九无间道名金刚喻定尽得俱尽智成无学应果",
  "flag": ""
 },
 {
  "id": "贤圣-47",
  "pin": "贤圣品",
  "localNo": 47,
  "globalNo": 467,
  "start": 255.48,
  "end": 260.92,
  "dur": 5.44,
  "nchars": 20,
  "text": "有顶由无漏余由二离染圣二离八修各二离系得",
  "flag": ""
 },
 {
  "id": "贤圣-48",
  "pin": "贤圣品",
  "localNo": 48,
  "globalNo": 468,
  "start": 260.92,
  "end": 266.28,
  "dur": 5.36,
  "nchars": 20,
  "text": "无漏未至道能离一切地余八离自上有漏离次下",
  "flag": ""
 },
 {
  "id": "贤圣-49",
  "pin": "贤圣品",
  "localNo": 49,
  "globalNo": 469,
  "start": 266.28,
  "end": 271.72,
  "dur": 5.44,
  "nchars": 20,
  "text": "近分离下染初三后解脱根本或近分上地唯根本",
  "flag": ""
 },
 {
  "id": "贤圣-50",
  "pin": "贤圣品",
  "localNo": 50,
  "globalNo": 470,
  "start": 271.72,
  "end": 277.16,
  "dur": 5.44,
  "nchars": 20,
  "text": "世无间解脱如次缘下上作粗苦障行及静妙离三",
  "flag": ""
 },
 {
  "id": "贤圣-51",
  "pin": "贤圣品",
  "localNo": 51,
  "globalNo": 471,
  "start": 277.16,
  "end": 282.62,
  "dur": 5.46,
  "nchars": 20,
  "text": "不动尽智后必起无生智余尽或正见此应果皆有",
  "flag": ""
 },
 {
  "id": "贤圣-52",
  "pin": "贤圣品",
  "localNo": 52,
  "globalNo": 472,
  "start": 282.85,
  "end": 288.1,
  "dur": 5.25,
  "nchars": 20,
  "text": "净道沙门性有为无为果此有八十九解脱道及灭",
  "flag": ""
 },
 {
  "id": "贤圣-53",
  "pin": "贤圣品",
  "localNo": 53,
  "globalNo": 473,
  "start": 288.1,
  "end": 293.48,
  "dur": 5.38,
  "nchars": 20,
  "text": "五因立四果舍曾得胜道集断得八智顿修十六行",
  "flag": ""
 },
 {
  "id": "贤圣-54",
  "pin": "贤圣品",
  "localNo": 54,
  "globalNo": 474,
  "start": 293.48,
  "end": 298.8,
  "dur": 5.32,
  "nchars": 20,
  "text": "世道所得断圣所得杂故无漏得持故亦名沙门果",
  "flag": ""
 },
 {
  "id": "贤圣-55",
  "pin": "贤圣品",
  "localNo": 55,
  "globalNo": 475,
  "start": 298.8,
  "end": 304.26,
  "dur": 5.46,
  "nchars": 20,
  "text": "所说沙门性亦名婆罗门亦名为梵轮真梵所转故",
  "flag": ""
 },
 {
  "id": "贤圣-56",
  "pin": "贤圣品",
  "localNo": 56,
  "globalNo": 476,
  "start": 304.26,
  "end": 309.68,
  "dur": 5.42,
  "nchars": 20,
  "text": "于中唯见道说名为法轮由速等似轮或具辐等故",
  "flag": ""
 },
 {
  "id": "贤圣-57",
  "pin": "贤圣品",
  "localNo": 57,
  "globalNo": 477,
  "start": 309.68,
  "end": 315.14,
  "dur": 5.46,
  "nchars": 20,
  "text": "三依欲后三由上无见道无闻无缘下无厌及经故",
  "flag": ""
 },
 {
  "id": "贤圣-58",
  "pin": "贤圣品",
  "localNo": 58,
  "globalNo": 478,
  "start": 315.14,
  "end": 320.62,
  "dur": 5.48,
  "nchars": 20,
  "text": "阿罗汉有六谓退至不动前五信解生总名时解脱",
  "flag": ""
 },
 {
  "id": "贤圣-59",
  "pin": "贤圣品",
  "localNo": 59,
  "globalNo": 479,
  "start": 320.62,
  "end": 326.0,
  "dur": 5.38,
  "nchars": 20,
  "text": "后不时解脱从前见至生有是先种性有后练根得",
  "flag": ""
 },
 {
  "id": "贤圣-60",
  "pin": "贤圣品",
  "localNo": 60,
  "globalNo": 480,
  "start": 326.19,
  "end": 331.46,
  "dur": 5.27,
  "nchars": 20,
  "text": "四从种姓退五从果非先学异生亦六练根非见道",
  "flag": ""
 },
 {
  "id": "贤圣-61",
  "pin": "贤圣品",
  "localNo": 61,
  "globalNo": 481,
  "start": 331.71,
  "end": 336.84,
  "dur": 5.13,
  "nchars": 20,
  "text": "应知退有三已未得受用佛唯有最后利中后钝三",
  "flag": ""
 },
 {
  "id": "贤圣-62",
  "pin": "贤圣品",
  "localNo": 62,
  "globalNo": 482,
  "start": 336.84,
  "end": 342.28,
  "dur": 5.44,
  "nchars": 20,
  "text": "一切从果退必得不命终住果所不为惭增故不作",
  "flag": ""
 },
 {
  "id": "贤圣-63",
  "pin": "贤圣品",
  "localNo": 63,
  "globalNo": 483,
  "start": 342.28,
  "end": 347.66,
  "dur": 5.38,
  "nchars": 20,
  "text": "练根无学位九无间解脱久习故学一无漏依人三",
  "flag": ""
 },
 {
  "id": "贤圣-64",
  "pin": "贤圣品",
  "localNo": 64,
  "globalNo": 484,
  "start": 347.66,
  "end": 353.16,
  "dur": 5.5,
  "nchars": 20,
  "text": "无学依九地有学但依六舍果胜果道唯得果道故",
  "flag": ""
 },
 {
  "id": "贤圣-65",
  "pin": "贤圣品",
  "localNo": 65,
  "globalNo": 485,
  "start": 353.16,
  "end": 358.54,
  "dur": 5.38,
  "nchars": 20,
  "text": "七声闻二佛差别由九根加行根灭定解脱故成七",
  "flag": ""
 },
 {
  "id": "贤圣-66",
  "pin": "贤圣品",
  "localNo": 66,
  "globalNo": 486,
  "start": 358.54,
  "end": 363.98,
  "dur": 5.44,
  "nchars": 20,
  "text": "此事别唯六三道各二故俱由得灭定余名慧解脱",
  "flag": ""
 },
 {
  "id": "贤圣-67",
  "pin": "贤圣品",
  "localNo": 67,
  "globalNo": 487,
  "start": 363.98,
  "end": 369.38,
  "dur": 5.4,
  "nchars": 20,
  "text": "有学名为满由根果定三无学得满名但由根定二",
  "flag": ""
 },
 {
  "id": "贤圣-68",
  "pin": "贤圣品",
  "localNo": 68,
  "globalNo": 488,
  "start": 369.6,
  "end": 374.82,
  "dur": 5.22,
  "nchars": 20,
  "text": "应知一切道略说唯有四谓加行无间解脱胜进道",
  "flag": ""
 },
 {
  "id": "贤圣-69",
  "pin": "贤圣品",
  "localNo": 69,
  "globalNo": 489,
  "start": 374.82,
  "end": 380.22,
  "dur": 5.4,
  "nchars": 20,
  "text": "通行有四种乐依本静虑苦依所余地迟速钝利根",
  "flag": ""
 },
 {
  "id": "贤圣-70",
  "pin": "贤圣品",
  "localNo": 70,
  "globalNo": 490,
  "start": 380.22,
  "end": 385.64,
  "dur": 5.42,
  "nchars": 20,
  "text": "觉分三十七谓四念住等觉谓尽无生顺此故名分",
  "flag": ""
 },
 {
  "id": "贤圣-71",
  "pin": "贤圣品",
  "localNo": 71,
  "globalNo": 491,
  "start": 385.64,
  "end": 391.08,
  "dur": 5.44,
  "nchars": 20,
  "text": "此实事唯十谓慧勤定信念喜舍轻安及戒寻为体",
  "flag": ""
 },
 {
  "id": "贤圣-72",
  "pin": "贤圣品",
  "localNo": 72,
  "globalNo": 492,
  "start": 391.08,
  "end": 396.5,
  "dur": 5.42,
  "nchars": 20,
  "text": "四念住正断神足随增上说为慧勤定实诸加行善",
  "flag": ""
 },
 {
  "id": "贤圣-73",
  "pin": "贤圣品",
  "localNo": 73,
  "globalNo": 493,
  "start": 396.5,
  "end": 401.96,
  "dur": 5.46,
  "nchars": 20,
  "text": "初业顺决择及修见道位念住等七品应知次第增",
  "flag": ""
 },
 {
  "id": "贤圣-74",
  "pin": "贤圣品",
  "localNo": 74,
  "globalNo": 494,
  "start": 401.96,
  "end": 407.28,
  "dur": 5.32,
  "nchars": 20,
  "text": "七觉八道支一向是无漏三四五根力皆通于二种",
  "flag": ""
 },
 {
  "id": "贤圣-75",
  "pin": "贤圣品",
  "localNo": 75,
  "globalNo": 495,
  "start": 407.28,
  "end": 412.56,
  "dur": 5.28,
  "nchars": 20,
  "text": "初静虑一切未至除喜根二静虑除寻三四中除二",
  "flag": ""
 },
 {
  "id": "贤圣-76",
  "pin": "贤圣品",
  "localNo": 76,
  "globalNo": 496,
  "start": 412.56,
  "end": 417.84,
  "dur": 5.28,
  "nchars": 20,
  "text": "前三无色地除戒前二种于欲界有顶除觉及道支",
  "flag": ""
 },
 {
  "id": "贤圣-77",
  "pin": "贤圣品",
  "localNo": 77,
  "globalNo": 497,
  "start": 417.84,
  "end": 423.24,
  "dur": 5.4,
  "nchars": 20,
  "text": "证净有四种谓佛法僧戒见三得法戒见道兼佛僧",
  "flag": ""
 },
 {
  "id": "贤圣-78",
  "pin": "贤圣品",
  "localNo": 78,
  "globalNo": 498,
  "start": 423.24,
  "end": 428.62,
  "dur": 5.38,
  "nchars": 20,
  "text": "法谓三谛全菩萨独觉道信戒二为体四皆唯无漏",
  "flag": ""
 },
 {
  "id": "贤圣-79",
  "pin": "贤圣品",
  "localNo": 79,
  "globalNo": 499,
  "start": 428.62,
  "end": 433.97,
  "dur": 5.35,
  "nchars": 20,
  "text": "学有余缚故无正脱智支解脱为无为谓胜解惑灭",
  "flag": ""
 },
 {
  "id": "贤圣-80",
  "pin": "贤圣品",
  "localNo": 80,
  "globalNo": 500,
  "start": 434.08,
  "end": 439.52,
  "dur": 5.44,
  "nchars": 20,
  "text": "有为无学支即二解脱蕴正智如觉说谓尽无生智",
  "flag": ""
 },
 {
  "id": "贤圣-81",
  "pin": "贤圣品",
  "localNo": 81,
  "globalNo": 501,
  "start": 439.52,
  "end": 444.88,
  "dur": 5.36,
  "nchars": 20,
  "text": "无学心生时正从障解脱道唯正灭位能令彼障断",
  "flag": ""
 },
 {
  "id": "贤圣-82",
  "pin": "贤圣品",
  "localNo": 82,
  "globalNo": 502,
  "start": 444.88,
  "end": 450.18,
  "dur": 5.3,
  "nchars": 20,
  "text": "无为说三界离界唯离贪断界断余结灭界灭彼事",
  "flag": ""
 },
 {
  "id": "贤圣-83",
  "pin": "贤圣品",
  "localNo": 83,
  "globalNo": 503,
  "start": 450.18,
  "end": 455.56,
  "dur": 5.38,
  "nchars": 20,
  "text": "厌缘苦集慧离缘四能断相对互广狭故应成四句",
  "flag": ""
 }
]