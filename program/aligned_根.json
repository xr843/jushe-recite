[
 {
  "id": "根-1",
  "pin": "根品",
  "localNo": 1,
  "globalNo": 48,
  "start": 0.0,
  "end": 5.46,
  "dur": 5.46,
  "nchars": 20,
  "text": "传说五于四四根于二种五八染净中各别为增上",
  "flag": ""
 },
 {
  "id": "根-2",
  "pin": "根品",
  "localNo": 2,
  "globalNo": 49,
  "start": 5.46,
  "end": 10.94,
  "dur": 5.48,
  "nchars": 20,
  "text": "了自境增上总立于六根从身立二根女男性增上",
  "flag": ""
 },
 {
  "id": "根-3",
  "pin": "根品",
  "localNo": 3,
  "globalNo": 50,
  "start": 10.94,
  "end": 16.38,
  "dur": 5.44,
  "nchars": 20,
  "text": "于同住杂染清净增上故应知命五受信等立为根",
  "flag": ""
 },
 {
  "id": "根-4",
  "pin": "根品",
  "localNo": 4,
  "globalNo": 51,
  "start": 16.38,
  "end": 21.78,
  "dur": 5.4,
  "nchars": 20,
  "text": "未当知已知具知根亦尔于得后后道涅槃等增上",
  "flag": ""
 },
 {
  "id": "根-5",
  "pin": "根品",
  "localNo": 5,
  "globalNo": 52,
  "start": 21.78,
  "end": 27.04,
  "dur": 5.26,
  "nchars": 20,
  "text": "心所依此别此住此杂染此资粮此净由此量立根",
  "flag": ""
 },
 {
  "id": "根-6",
  "pin": "根品",
  "localNo": 6,
  "globalNo": 53,
  "start": 27.04,
  "end": 32.46,
  "dur": 5.42,
  "nchars": 20,
  "text": "或流转所依及生住受用建立前十四还灭后亦然",
  "flag": ""
 },
 {
  "id": "根-7",
  "pin": "根品",
  "localNo": 7,
  "globalNo": 54,
  "start": 32.46,
  "end": 38.06,
  "dur": 5.6,
  "nchars": 20,
  "text": "身不悦名苦即此悦名乐及三定心悦余处此名喜",
  "flag": ""
 },
 {
  "id": "根-8",
  "pin": "根品",
  "localNo": 8,
  "globalNo": 55,
  "start": 38.06,
  "end": 43.76,
  "dur": 5.7,
  "nchars": 20,
  "text": "心不悦名忧中舍二无别见修无学道依九立三根",
  "flag": ""
 },
 {
  "id": "根-9",
  "pin": "根品",
  "localNo": 9,
  "globalNo": 56,
  "start": 43.76,
  "end": 49.48,
  "dur": 5.72,
  "nchars": 20,
  "text": "唯无漏后三有色命忧苦当知唯有漏通二余九根",
  "flag": ""
 },
 {
  "id": "根-10",
  "pin": "根品",
  "localNo": 10,
  "globalNo": 57,
  "start": 49.48,
  "end": 55.2,
  "dur": 5.72,
  "nchars": 20,
  "text": "命唯是异熟忧及后八非色意余四受一一皆通二",
  "flag": ""
 },
 {
  "id": "根-11",
  "pin": "根品",
  "localNo": 11,
  "globalNo": 58,
  "start": 55.2,
  "end": 60.9,
  "dur": 5.7,
  "nchars": 20,
  "text": "忧定有异熟前八后三无意余受信等一一皆通二",
  "flag": ""
 },
 {
  "id": "根-12",
  "pin": "根品",
  "localNo": 12,
  "globalNo": 59,
  "start": 60.9,
  "end": 66.54,
  "dur": 5.64,
  "nchars": 20,
  "text": "唯善后八根忧通善不善意余受三种前八唯无记",
  "flag": ""
 },
 {
  "id": "根-13",
  "pin": "根品",
  "localNo": 13,
  "globalNo": 60,
  "start": 66.54,
  "end": 72.22,
  "dur": 5.68,
  "nchars": 20,
  "text": "欲色无色界如次除后三兼女男忧苦并余色喜乐",
  "flag": ""
 },
 {
  "id": "根-14",
  "pin": "根品",
  "localNo": 14,
  "globalNo": 61,
  "start": 72.22,
  "end": 77.8,
  "dur": 5.58,
  "nchars": 20,
  "text": "意三受通三忧见修所断九唯修所断五修非三非",
  "flag": ""
 },
 {
  "id": "根-15",
  "pin": "根品",
  "localNo": 15,
  "globalNo": 62,
  "start": 77.8,
  "end": 83.34,
  "dur": 5.54,
  "nchars": 20,
  "text": "欲胎卵湿生初得二异熟化生六七八色六上唯命",
  "flag": ""
 },
 {
  "id": "根-16",
  "pin": "根品",
  "localNo": 16,
  "globalNo": 63,
  "start": 83.34,
  "end": 88.92,
  "dur": 5.58,
  "nchars": 20,
  "text": "正死灭诸根无色三色八欲顿十九八渐四善增五",
  "flag": ""
 },
 {
  "id": "根-17",
  "pin": "根品",
  "localNo": 17,
  "globalNo": 64,
  "start": 88.92,
  "end": 94.42,
  "dur": 5.5,
  "nchars": 20,
  "text": "九得边二果七八九中二十一阿罗汉依一容有说",
  "flag": ""
 },
 {
  "id": "根-18",
  "pin": "根品",
  "localNo": 18,
  "globalNo": 65,
  "start": 94.42,
  "end": 99.92,
  "dur": 5.5,
  "nchars": 20,
  "text": "成就命意舍各定成就三若成就乐身各定成就四",
  "flag": ""
 },
 {
  "id": "根-19",
  "pin": "根品",
  "localNo": 19,
  "globalNo": 66,
  "start": 99.92,
  "end": 105.44,
  "dur": 5.52,
  "nchars": 20,
  "text": "成眼等及喜各定成五根若成就苦根彼定成就七",
  "flag": ""
 },
 {
  "id": "根-20",
  "pin": "根品",
  "localNo": 20,
  "globalNo": 67,
  "start": 105.44,
  "end": 110.96,
  "dur": 5.52,
  "nchars": 20,
  "text": "若成女男忧信等各成八二无漏十一初无漏十三",
  "flag": ""
 },
 {
  "id": "根-21",
  "pin": "根品",
  "localNo": 21,
  "globalNo": 68,
  "start": 111.17,
  "end": 116.44,
  "dur": 5.27,
  "nchars": 20,
  "text": "极少八无善成受身命意愚生无色界成善命意舍",
  "flag": ""
 },
 {
  "id": "根-22",
  "pin": "根品",
  "localNo": 22,
  "globalNo": 69,
  "start": 116.44,
  "end": 122.0,
  "dur": 5.56,
  "nchars": 20,
  "text": "极多成十九二形除三净圣者未离欲除二净一形",
  "flag": ""
 },
 {
  "id": "根-23",
  "pin": "根品",
  "localNo": 23,
  "globalNo": 70,
  "start": 122.0,
  "end": 127.76,
  "dur": 5.76,
  "nchars": 20,
  "text": "欲微聚无声无根有八事有身根九事十事有余根",
  "flag": ""
 },
 {
  "id": "根-24",
  "pin": "根品",
  "localNo": 24,
  "globalNo": 71,
  "start": 127.76,
  "end": 133.52,
  "dur": 5.76,
  "nchars": 20,
  "text": "心心所必俱诸行相或得心所且有五大地法等异",
  "flag": ""
 },
 {
  "id": "根-25",
  "pin": "根品",
  "localNo": 25,
  "globalNo": 72,
  "start": 133.52,
  "end": 139.2,
  "dur": 5.68,
  "nchars": 20,
  "text": "受想思触欲慧念与作意胜解三摩地遍于一切心",
  "flag": ""
 },
 {
  "id": "根-26",
  "pin": "根品",
  "localNo": 26,
  "globalNo": 73,
  "start": 139.2,
  "end": 144.92,
  "dur": 5.72,
  "nchars": 20,
  "text": "信及不放逸轻安舍惭愧二根及不害勤唯遍善心",
  "flag": ""
 },
 {
  "id": "根-27",
  "pin": "根品",
  "localNo": 27,
  "globalNo": 74,
  "start": 144.92,
  "end": 150.6,
  "dur": 5.68,
  "nchars": 20,
  "text": "痴逸怠不信昏掉恒唯染唯遍不善心无惭及无愧",
  "flag": ""
 },
 {
  "id": "根-28",
  "pin": "根品",
  "localNo": 28,
  "globalNo": 75,
  "start": 150.6,
  "end": 155.97,
  "dur": 5.37,
  "nchars": 20,
  "text": "忿覆悭嫉恼害恨谄诳骄如是类名为小烦恼地法",
  "flag": ""
 },
 {
  "id": "根-29",
  "pin": "根品",
  "localNo": 29,
  "globalNo": 76,
  "start": 156.04,
  "end": 162.0,
  "dur": 5.96,
  "nchars": 20,
  "text": "欲有寻伺故于善心品中二十二心所有时增恶作",
  "flag": ""
 },
 {
  "id": "根-30",
  "pin": "根品",
  "localNo": 30,
  "globalNo": 77,
  "start": 162.0,
  "end": 167.74,
  "dur": 5.74,
  "nchars": 20,
  "text": "于不善不共见俱唯二十四烦恼忿等恶作二十一",
  "flag": ""
 },
 {
  "id": "根-31",
  "pin": "根品",
  "localNo": 31,
  "globalNo": 78,
  "start": 167.74,
  "end": 173.42,
  "dur": 5.68,
  "nchars": 20,
  "text": "有覆有十八无覆许十二睡眠遍不违若有皆增一",
  "flag": ""
 },
 {
  "id": "根-32",
  "pin": "根品",
  "localNo": 32,
  "globalNo": 79,
  "start": 173.42,
  "end": 179.06,
  "dur": 5.64,
  "nchars": 20,
  "text": "初定除不善及恶作睡眠中定又除寻上兼除伺等",
  "flag": ""
 },
 {
  "id": "根-33",
  "pin": "根品",
  "localNo": 33,
  "globalNo": 80,
  "start": 179.06,
  "end": 184.78,
  "dur": 5.72,
  "nchars": 20,
  "text": "无惭愧不重于罪不见怖爱敬谓信惭唯于欲色有",
  "flag": ""
 },
 {
  "id": "根-34",
  "pin": "根品",
  "localNo": 34,
  "globalNo": 81,
  "start": 184.78,
  "end": 190.52,
  "dur": 5.74,
  "nchars": 20,
  "text": "寻伺心粗细慢对他心举骄由染自法心高无所顾",
  "flag": ""
 },
 {
  "id": "根-35",
  "pin": "根品",
  "localNo": 35,
  "globalNo": 82,
  "start": 190.52,
  "end": 196.14,
  "dur": 5.62,
  "nchars": 20,
  "text": "心意识体一心心所有依有缘有行相相应义有五",
  "flag": ""
 },
 {
  "id": "根-36",
  "pin": "根品",
  "localNo": 36,
  "globalNo": 83,
  "start": 196.14,
  "end": 201.8,
  "dur": 5.66,
  "nchars": 20,
  "text": "心不相应行得非得同分无想二定命相名身等类",
  "flag": ""
 },
 {
  "id": "根-37",
  "pin": "根品",
  "localNo": 37,
  "globalNo": 84,
  "start": 201.8,
  "end": 207.22,
  "dur": 5.42,
  "nchars": 20,
  "text": "得谓获成就非得此相违得非得唯于自相续二灭",
  "flag": ""
 },
 {
  "id": "根-38",
  "pin": "根品",
  "localNo": 38,
  "globalNo": 85,
  "start": 207.36,
  "end": 212.86,
  "dur": 5.5,
  "nchars": 20,
  "text": "三世法各三善等唯善等有系自界得无系得通四",
  "flag": ""
 },
 {
  "id": "根-39",
  "pin": "根品",
  "localNo": 39,
  "globalNo": 86,
  "start": 212.96,
  "end": 218.66,
  "dur": 5.7,
  "nchars": 20,
  "text": "非学无学三非所断二种无记得俱起除二通变化",
  "flag": ""
 },
 {
  "id": "根-40",
  "pin": "根品",
  "localNo": 40,
  "globalNo": 87,
  "start": 218.66,
  "end": 224.34,
  "dur": 5.68,
  "nchars": 20,
  "text": "有覆色亦俱欲色无前起非得净无记去来世各三",
  "flag": ""
 },
 {
  "id": "根-41",
  "pin": "根品",
  "localNo": 41,
  "globalNo": 88,
  "start": 224.34,
  "end": 230.06,
  "dur": 5.72,
  "nchars": 20,
  "text": "三界不系三许圣道非得说名异生性得法易地舍",
  "flag": ""
 },
 {
  "id": "根-42",
  "pin": "根品",
  "localNo": 42,
  "globalNo": 89,
  "start": 230.06,
  "end": 235.76,
  "dur": 5.7,
  "nchars": 20,
  "text": "同分有情等无想无想中心心所法灭异熟居广果",
  "flag": ""
 },
 {
  "id": "根-43",
  "pin": "根品",
  "localNo": 43,
  "globalNo": 90,
  "start": 235.76,
  "end": 241.44,
  "dur": 5.68,
  "nchars": 20,
  "text": "如是无想定后静虑求脱善唯顺生受非圣得一世",
  "flag": ""
 },
 {
  "id": "根-44",
  "pin": "根品",
  "localNo": 44,
  "globalNo": 91,
  "start": 241.44,
  "end": 247.04,
  "dur": 5.6,
  "nchars": 20,
  "text": "灭尽定亦然为静住有顶善二受不定圣由加行得",
  "flag": ""
 },
 {
  "id": "根-45",
  "pin": "根品",
  "localNo": 45,
  "globalNo": 92,
  "start": 247.04,
  "end": 252.76,
  "dur": 5.72,
  "nchars": 20,
  "text": "成佛得非前三十四念故二定依欲色灭定初人中",
  "flag": ""
 },
 {
  "id": "根-46",
  "pin": "根品",
  "localNo": 46,
  "globalNo": 93,
  "start": 252.76,
  "end": 258.32,
  "dur": 5.56,
  "nchars": 20,
  "text": "命根体即寿能持暖及识相谓诸有为生住异灭性",
  "flag": ""
 },
 {
  "id": "根-47",
  "pin": "根品",
  "localNo": 47,
  "globalNo": 94,
  "start": 258.32,
  "end": 263.92,
  "dur": 5.6,
  "nchars": 20,
  "text": "此有生生等于八一有能生能生所生非离因缘合",
  "flag": ""
 },
 {
  "id": "根-48",
  "pin": "根品",
  "localNo": 48,
  "globalNo": 95,
  "start": 263.92,
  "end": 269.56,
  "dur": 5.64,
  "nchars": 20,
  "text": "名身等所谓想章字总说欲色有情摄等流无记性",
  "flag": ""
 },
 {
  "id": "根-49",
  "pin": "根品",
  "localNo": 49,
  "globalNo": 96,
  "start": 269.56,
  "end": 275.22,
  "dur": 5.66,
  "nchars": 20,
  "text": "同分亦如是并无色异熟得相通三类非得定等流",
  "flag": ""
 },
 {
  "id": "根-50",
  "pin": "根品",
  "localNo": 50,
  "globalNo": 97,
  "start": 275.22,
  "end": 280.84,
  "dur": 5.62,
  "nchars": 20,
  "text": "能作及俱有同类与相应遍行并异熟许因唯六种",
  "flag": ""
 },
 {
  "id": "根-51",
  "pin": "根品",
  "localNo": 51,
  "globalNo": 98,
  "start": 280.84,
  "end": 286.48,
  "dur": 5.64,
  "nchars": 20,
  "text": "除自余能作俱有互为果如大相所相心于心随转",
  "flag": ""
 },
 {
  "id": "根-52",
  "pin": "根品",
  "localNo": 52,
  "globalNo": 99,
  "start": 286.48,
  "end": 292.04,
  "dur": 5.56,
  "nchars": 20,
  "text": "心所二律仪彼及心诸相是心随转法由时果善等",
  "flag": ""
 },
 {
  "id": "根-53",
  "pin": "根品",
  "localNo": 53,
  "globalNo": 100,
  "start": 292.04,
  "end": 297.62,
  "dur": 5.58,
  "nchars": 20,
  "text": "同类因相似自部地前生道展转九地唯等胜为果",
  "flag": ""
 },
 {
  "id": "根-54",
  "pin": "根品",
  "localNo": 54,
  "globalNo": 101,
  "start": 297.62,
  "end": 303.26,
  "dur": 5.64,
  "nchars": 20,
  "text": "加行生亦然闻思所成等相应因决定心心所同依",
  "flag": ""
 },
 {
  "id": "根-55",
  "pin": "根品",
  "localNo": 55,
  "globalNo": 102,
  "start": 303.26,
  "end": 308.88,
  "dur": 5.62,
  "nchars": 20,
  "text": "遍行谓前遍为同地染因异熟因不善及善唯有漏",
  "flag": ""
 },
 {
  "id": "根-56",
  "pin": "根品",
  "localNo": 56,
  "globalNo": 103,
  "start": 308.88,
  "end": 314.4,
  "dur": 5.52,
  "nchars": 20,
  "text": "遍行与同类二世三世三果有为离系无为无因果",
  "flag": ""
 },
 {
  "id": "根-57",
  "pin": "根品",
  "localNo": 57,
  "globalNo": 104,
  "start": 314.4,
  "end": 320.12,
  "dur": 5.72,
  "nchars": 20,
  "text": "后因果异熟前因增上果同类遍等流俱相应士用",
  "flag": ""
 },
 {
  "id": "根-58",
  "pin": "根品",
  "localNo": 58,
  "globalNo": 105,
  "start": 320.12,
  "end": 325.68,
  "dur": 5.56,
  "nchars": 20,
  "text": "异熟无记法有情有记生等流似自因离系由慧尽",
  "flag": ""
 },
 {
  "id": "根-59",
  "pin": "根品",
  "localNo": 59,
  "globalNo": 106,
  "start": 325.76,
  "end": 331.34,
  "dur": 5.58,
  "nchars": 20,
  "text": "若因彼力生是果名士用除前有为法有为增上果",
  "flag": ""
 },
 {
  "id": "根-60",
  "pin": "根品",
  "localNo": 60,
  "globalNo": 107,
  "start": 331.34,
  "end": 337.02,
  "dur": 5.68,
  "nchars": 20,
  "text": "五取果唯现二与果亦然过现与二因一与唯过去",
  "flag": ""
 },
 {
  "id": "根-61",
  "pin": "根品",
  "localNo": 61,
  "globalNo": 108,
  "start": 337.24,
  "end": 342.62,
  "dur": 5.38,
  "nchars": 20,
  "text": "染污异熟生余初圣如次除异熟遍二及同类余生",
  "flag": ""
 },
 {
  "id": "根-62",
  "pin": "根品",
  "localNo": 62,
  "globalNo": 109,
  "start": 342.62,
  "end": 348.22,
  "dur": 5.6,
  "nchars": 20,
  "text": "此谓心心所余及除相应说有四种缘因缘五因性",
  "flag": ""
 },
 {
  "id": "根-63",
  "pin": "根品",
  "localNo": 63,
  "globalNo": 110,
  "start": 348.22,
  "end": 353.76,
  "dur": 5.54,
  "nchars": 20,
